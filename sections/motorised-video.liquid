<div class="page-width my-12!">
  <div class="relative w-full aspect-video md:aspect-[21/9] bg-gray-200 rounded-lg overflow-hidden flex items-center justify-center pointer-events-none">
    {% if section.settings.video != blank %}
      {{
        section.settings.video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          image_size: '1400x',
          class: 'absolute inset-0 w-full h-full object-cover'
      }}
    {% elsif section.settings.cover_image != blank %}
      <img
        src="{{ section.settings.cover_image | image_url: width: 1400 }}"
        alt="{{ section.settings.cover_image.alt | escape }}"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
        width="auto"
        height="auto"
      >
    {% else %}
      <div class="absolute inset-0 w-full h-full bg-gray-300 flex items-center justify-center text-gray-500">
        Select Video
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Motorised Video",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "info": "Upload an MP4 video. It will play automatically, loop continuously, and have no sound."
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Fallback Image",
      "info": "Displayed if the video fails to load or before it begins playing."
    }
  ],
  "presets": [
    {
      "name": "Motorised Video"
    }
  ]
}
{% endschema %}

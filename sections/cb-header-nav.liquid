<style>
  .cb-header-nav {
    background-color: #000;
    color: #fff;
  }
  .cb-header-nav .page-width{
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .cb-nav-menu {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
  }
  .cb-nav-left{
    display: block !important;
  }
  .cb-nav-item {
    position: relative;
    padding: 15px 0;
  }
  .cb-nav-link {
    color: #fff;
    text-decoration: none;
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 5px;
    transition: opacity 0.3s ease;
    border-radius: 20px;
    padding: 6px 16px;
  }
  .cb-nav-item:hover > .cb-nav-link, .cb-nav-link:hover {
    background-color: #FFB800;
  }
  .cb-nav-link svg {
    width: 10px;
    height: 10px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    margin-bottom: -2px;
  }
  .cb-social-icons {
    display: flex;
    gap: 15px;
    align-items: center;
  }
  .cb-social-link {
    color: #fff;
    display: inline-flex;
    transition: opacity 0.3s ease;
  }
  .cb-social-link svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
  }

  /* Dropdown Styles */
  .cb-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    margin: 0;
    padding: 0;
    list-style: none;
    background: #fff;
    border: 1px solid #ddd;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    min-width: 240px;
    z-index: 100;
  }
  .cb-nav-item:hover .cb-dropdown {
    display: block;
    z-index: 99999;
  }
  .cb-dropdown-item {
    border-bottom: 1px solid #eee;
  }
  .cb-dropdown-item:last-child {
    border-bottom: none;
  }
  .cb-dropdown-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    color: #333;
    text-decoration: none;
    font-size: 13px;
    transition: background 0.2s, color 0.2s;
  }
  .cb-dropdown-link:hover {
    background: #fdfdfd;
    color: #FFB800;
  }
  .cb-dropdown-link img {
    width: 20px;
    height: 20px;
    object-fit: contain;
  }
  .cb-dropdown-link svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }

  /* Ensure dropdown overlaps the reviews banner below it */
  #shopify-section-{{ section.id }} {
    position: relative;
    z-index: 999;
  }

  .cb-nav-item-mega {
    position: static;
  }
  .cb-mega-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 5%;
    right: 5%;
    background: #fff;
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    padding: 40px;
    z-index: 100;
  }
  .cb-nav-item-mega:hover .cb-mega-menu {
    display: block;
  }
  .cb-mega-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(130px, 1fr));
    gap: 30px 20px;
  }
  .cb-color-collection-link {
    display: flex;
    flex-direction: rows;
    align-items: center;
    gap: 12px;
    color: #000;
    text-decoration: none;
    font-size: 20px;
    font-weight: 400;
    text-align: center;
    transition: transform 0.2s;
  }
  .cb-color-collection-link:hover {
    color: #FFB800;
    transform: translateY(-2px);
  }
  .cb-color-collection-image {
    width: 36px;
    height: 36px;
    overflow: hidden;
    background: #f8f8f8;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  }
  .cb-color-collection-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cb-mega-close {
    position: absolute;
    top: 15px;
    right: 15px;
    cursor: pointer;
    background: #f0f0f0;
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .cb-mega-close:hover {
    background: #e0e0e0;
  }

  /* Help & Advice Mega Menu */
  .cb-help-mega-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 5%;
    right: 5%;
    background: #fff;
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    padding: 40px 30px 30px;
    z-index: 100;
  }
  .cb-nav-item-mega:hover .cb-help-mega-menu {
    display: block;
  }
  .cb-help-grid {
    display: flex;
    justify-content: space-between;
    gap: 30px;
  }
  .cb-help-col {
    flex: 1;
  }
  .cb-help-heading {
    color: #FFB800;
    font-size: 24px;
    font-weight: 500;
    margin-top: 0;
    margin-bottom: 20px;
  }
  .cb-help-links-2col {
    display: flex;
    gap: 40px;
  }
  .cb-help-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .cb-help-list a {
    color: #000;
    text-decoration: none;
    font-size: 20px;
    transition: color 0.2s;
  }
  .cb-help-list a:hover {
    color: #FFB800;
  }
  .cb-help-box-col {
    flex: 0 0 320px;
    display: flex;
    align-items: end;
  }
  .cb-help-box {
    background-color: #FAEDD5;
    padding: 10px;
    border-radius: 6px;
  }
  .cb-help-box h4 {
    margin: 0 0 10px 0;
    font-size: 18px;
    color: #000;
    font-weight: 600;
  }
  .cb-help-box p {
    margin: 0 0 20px 0;
    font-size: 16px;
    color: #000;
    line-height: 1.5;
  }
  .cb-help-btn {
    display: inline-block;
    background-color: #FFB800;
    color: #000;
    padding: 6px 14px;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
    font-size: 16px;
    transition: opacity 0.2s;
  }
  .cb-help-btn:hover {
    opacity: 0.9;
  }


<!-- sections/installment-banner.liquid -->

<style>
  .installment-banner {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .installment-banner__link {
    display: block;
    text-decoration: none;
    border-radius: {{ section.settings.border_radius }}px;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .installment-banner__link:hover {
    transform: scale(1.01);
  }

  .installment-banner__media {
    position: relative;
    width: 100%;
    /* Use CSS aspect-ratio with fallback */
    aspect-ratio: {{ section.settings.aspect_ratio | default: '16 / 6' }};
    background-color: #f0f0f0;
    overflow: hidden;
  }

  .installment-banner__media img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Support for separate mobile aspect ratio */
  @media screen and (max-width: 749px) {
    .installment-banner__media {
      aspect-ratio: {{ section.settings.mobile_aspect_ratio | default: '4 / 3' }};
    }
  }
</style>

<div class="installment-banner section-{{ section.id }}-padding">
  <div class="page-width">
    <a href="{{ section.settings.link | default: '#' }}" class="installment-banner__link">
      <div class="installment-banner__media">
        {%- if section.settings.image != blank -%}
          {%- capture sizes -%}
            (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px, (min-width: 750px) calc(100vw - 10rem), 100vw
          {%- endcapture -%}
          {{
            section.settings.image
            | image_url: width: 3200
            | image_tag:
              loading: 'lazy',
              sizes: sizes,
              widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3200',
              class: 'installment-banner__image'
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Installment Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner Image (Desktop)"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Banner Link"
    },
    {
      "type": "text",
      "id": "aspect_ratio",
      "label": "Aspect Ratio (Desktop)",
      "default": "2.5 / 1",
      "info": "Example: 16 / 9, 2.5 / 1, 3 / 1"
    },
    {
      "type": "text",
      "id": "mobile_aspect_ratio",
      "label": "Aspect Ratio (Mobile)",
      "default": "2 / 1",
      "info": "Example: 1 / 1, 4 / 3, 2 / 1"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Installment Banner"
    }
  ]
}
{% endschema %}

{{ 'custom-footer.css' | asset_url | stylesheet_tag }}

<footer
  class="custom-footer"
  style="--footer-bg-color: {{ section.settings.bg_color }}; --footer-text-color: {{ section.settings.text_color }}; --heading-size-desktop: {{ section.settings.heading_size_desktop }}px; --heading-size-mobile: {{ section.settings.heading_size_mobile }}px; --text-size-desktop: {{ section.settings.text_size_desktop }}px; --text-size-mobile: {{ section.settings.text_size_mobile }}px;"
>
  <div class="page-width">
    <div class="custom-footer__grid">
      <!-- Left Column (Image & Contact) -->
      <div class="custom-footer__col-left">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            class="custom-footer__main-img"
            alt=""
            loading="lazy"
            style="width: {{ section.settings.img_width }}px; {% if section.settings.img_center_auto %}top: 50%; left: 50%; transform: translate(-50%, -50%); bottom: auto;{% else %}top: {{ section.settings.img_top }}%; left: {{ section.settings.img_left }}%; bottom: auto; transform: none;{% endif %}"
          >
        {%- endif -%}

        <div class="custom-footer__col-left-content">
          {%- if section.settings.contact_heading != blank -%}
            <h3>{{ section.settings.contact_heading }}</h3>
          {%- endif -%}

          <div class="custom-footer__contact-info">
            {%- if section.settings.timing_1 != blank or section.settings.timing_2 != blank -%}
              <div class="custom-footer__contact-item">
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 20 21"
                  fill="none"
                  stroke-width="1.5"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="M4.29141 0.0820293C4.02891 0.241404 3.99141 0.339842 3.99141 0.864841V1.34297L3.16172 1.36172C2.42109 1.38047 2.28516 1.39922 1.95234 1.50703C1.01016 1.8164 0.278906 2.62734 0.0773438 3.58359C-0.0257813 4.0664 -0.0257813 17.5289 0.0773438 18.0117C0.297656 19.0617 1.18828 19.9523 2.23828 20.1727C2.72578 20.2758 16.507 20.2758 16.9992 20.1727C18.0398 19.957 18.9352 19.0617 19.1555 18.0117C19.2586 17.5289 19.2586 4.0664 19.1555 3.58359C18.9539 2.62734 18.2227 1.82109 17.257 1.49297C16.9992 1.4039 16.8164 1.38515 16.0992 1.3664L15.2414 1.34297V0.860153C15.2414 0.442966 15.2273 0.363279 15.143 0.255466C14.9461 0.00702858 14.6742 -0.0632839 14.3742 0.0585918C14.1023 0.171091 14.0227 0.363279 14.0227 0.892965V1.35234H9.61641H5.21016V0.892965C5.21016 0.517965 5.19141 0.410154 5.11641 0.28359C4.94766 0.0117168 4.56328 -0.0820332 4.29141 0.0820293ZM3.99141 3.04453C3.99141 3.35859 4.01016 3.5039 4.07109 3.60234C4.26328 3.93047 4.76016 3.97734 5.04141 3.70078C5.18203 3.56015 5.18672 3.53672 5.20078 3.08672L5.21953 2.61797H9.61641H14.0133L14.032 3.08672C14.0461 3.53672 14.0508 3.56015 14.1914 3.70078C14.4727 3.97734 14.9695 3.93047 15.1617 3.60234C15.2227 3.5039 15.2414 3.35859 15.2414 3.03984V2.60859L16.0289 2.62734C16.7461 2.6414 16.8305 2.65078 17.0461 2.7539C17.3789 2.91797 17.7445 3.30703 17.8617 3.62578C17.9508 3.86015 17.9602 3.98672 17.9602 4.91484V5.94609H9.61641H1.27266V4.91484C1.27266 4.00547 1.28203 3.86015 1.36641 3.63984C1.47891 3.33984 1.67578 3.08672 1.96172 2.88984C2.29453 2.66484 2.48672 2.62265 3.27891 2.62265L3.99141 2.61797V3.04453ZM17.9602 12.4617V17.707L17.857 17.9789C17.7211 18.3492 17.332 18.7383 16.9617 18.8742L16.6898 18.9773H9.61641H2.54297L2.27109 18.8742C1.90078 18.7383 1.51172 18.3492 1.37578 17.9789L1.27266 17.707V12.4617V7.21172H9.61641H17.9602V12.4617Z" fill="black"/>
                  <path d="M4.39063 9.59528C3.78594 9.75466 3.43438 10.214 3.42969 10.8468C3.42969 11.5781 3.93594 12.089 4.66719 12.0937C5.375 12.0984 5.96094 11.5312 5.96094 10.8422C5.96094 10.3922 5.62813 9.86716 5.22969 9.68903C5.00469 9.58591 4.59219 9.54372 4.39063 9.59528Z" fill="black"/>
                  <path d="M9.30406 9.59531C8.91031 9.69844 8.54 10.0406 8.40875 10.4391C8.315 10.7062 8.33843 11.0953 8.465 11.3578C8.68531 11.8359 9.08843 12.0938 9.60406 12.0938C9.97906 12.0891 10.2041 12.0094 10.4666 11.7703C10.715 11.5453 10.8416 11.2875 10.8697 10.95C10.9212 10.4156 10.6634 9.94219 10.2134 9.71719C9.93687 9.58594 9.5525 9.53437 9.30406 9.59531Z" fill="black"/>
                  <path d="M14.1172 9.64135C13.6437 9.8101 13.2734 10.3351 13.2734 10.8413C13.2734 11.1085 13.4094 11.4554 13.6016 11.671C14.0516 12.1867 14.8766 12.2382 15.4156 11.7835C15.9031 11.371 15.9453 10.5085 15.5 9.98354C15.1953 9.6226 14.5906 9.4726 14.1172 9.64135Z" fill="black"/>
                  <path d="M4.39063 13.6734C3.78594 13.8328 3.43438 14.2922 3.42969 14.925C3.42969 15.6562 3.93594 16.1672 4.66719 16.1718C5.375 16.1765 5.96094 15.6093 5.96094 14.9203C5.96094 14.4703 5.64688 13.9734 5.24375 13.7765C5.01875 13.6687 4.60156 13.6172 4.39063 13.6734Z" fill="black"/>
                  <path d="M9.30333 13.675C8.90958 13.7781 8.53926 14.1203 8.40801 14.5188C8.25333 14.9688 8.40333 15.5219 8.77364 15.85C9.03614 16.0891 9.22364 16.1641 9.5752 16.1641C9.96895 16.1641 10.194 16.0891 10.4424 15.8688C10.7096 15.6344 10.8408 15.3766 10.869 15.0297C10.9205 14.4953 10.6627 14.0219 10.2127 13.7969C9.93614 13.6656 9.55176 13.6141 9.30333 13.675Z" fill="black"/>
                  <path d="M14.2437 13.6823C13.9719 13.7526 13.8266 13.8416 13.6156 14.0713C13.4141 14.2916 13.2734 14.6432 13.2734 14.9245C13.2734 15.4354 13.6766 15.9932 14.1406 16.1198C14.7969 16.3026 15.4062 16.0588 15.6828 15.501C15.9078 15.0463 15.8328 14.4604 15.5 14.0666C15.2375 13.7526 14.6656 13.5791 14.2437 13.6823Z" fill="black"/>
                </svg>

                <div>
                  {%- if section.settings.timing_1 != blank -%}
                    <div>{{ section.settings.timing_1 }}</div>
                  {%- endif -%}
                  {%- if section.settings.timing_2 != blank -%}
                    <div>{{ section.settings.timing_2 }}</div>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}

            {%- if section.settings.phone != blank -%}
              <div class="custom-footer__contact-item">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
                <div>
                  <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}">
                    {{- section.settings.phone -}}
                  </a>
                </div>
              </div>
            {%- endif -%}

            {%- if section.settings.address != blank -%}
              <div class="custom-footer__contact-item">
                <svg
                  width="26"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke-width="1.5"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="M12 13.4304C13.7231 13.4304 15.12 12.0336 15.12 10.3104C15.12 8.5873 13.7231 7.19043 12 7.19043C10.2769 7.19043 8.88 8.5873 8.88 10.3104C8.88 12.0336 10.2769 13.4304 12 13.4304Z" stroke="black"/>
                  <path d="M3.62001 8.49C5.59001 -0.169998 18.42 -0.159997 20.38 8.5C21.53 13.58 18.37 17.88 15.6 20.54C13.59 22.48 10.41 22.48 8.39001 20.54C5.63001 17.88 2.47001 13.57 3.62001 8.49Z" stroke="black"/>
                </svg>

                <div>
                  <a
                    href="https://maps.google.com/?q={{ section.settings.address | url_encode }}"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {{- section.settings.address | newline_to_br -}}
                  </a>
                </div>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>

      <!-- Right Column (Menus, Payment, Newsletter) -->
      <!-- Right Column (Menus, Payment, Newsletter) -->
      <div class="custom-footer__col-right">
        <div class="custom-footer__menus">
          {%- for i in (1..3) -%}
            {%- capture menu_setting -%}menu_{{ i }}{%- endcapture -%}
            {%- capture menu_heading_setting -%}menu_heading_{{ i }}{%- endcapture -%}
            {%- assign menu = section.settings[menu_setting] -%}
            {%- assign heading = section.settings[menu_heading_setting] -%}

            {%- if menu != blank or heading != blank -%}
              <div class="custom-footer__menu-col">
                <h3>{{ heading }}</h3>
                <ul>
                  {%- for link in menu.links -%}
                    <li>
                      <a href="{{ link.url }}">{{ link.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="custom-footer__bottom-row">
          <div class="custom-footer__payment">
            <div class="custom-footer__payment-title">Choose Your Payment Method</div>
            <div class="custom-footer__payment-icons">
              {%- assign has_payment_blocks = false -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'payment_image' -%}
                  {%- assign has_payment_blocks = true -%}
                  {%- if block.settings.image != blank -%}
                    <div class="payment-icon-box">
                      <img
                        src="{{ block.settings.image | image_url: width: 100 }}"
                        alt="{{ block.settings.image.alt | escape }}"
                        loading="lazy"
                        class="payment-icon-img"
                      >
                    </div>
                  {%- else -%}
                    <div class="payment-icon-placeholder" {{ block.shopify_attributes }}>
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}

              {%- if has_payment_blocks == false -%}
                {% assign default_methods = 'visa,apple_pay,master,google_pay,tabby,tamara' | split: ',' %}
                {% for type in default_methods %}
                  {% assign payment_img = type | append: '.webp' %}
                  <div class="payment-icon-box">
                    <img
                      src="{{ payment_img | asset_url }}"
                      alt="{{ type | replace: '_', ' ' | capitalize }}"
                      class="payment-icon-img"
                      loading="lazy"
                    >
                  </div>
                {% endfor %}
              {%- endif -%}
            </div>
          </div>

          <div class="custom-footer__newsletter">
            <div class="custom-footer__newsletter-title">{{ section.settings.newsletter_heading }}</div>
            {%- form 'customer', class: 'custom-footer__newsletter-form' -%}
              <input
                type="email"
                name="contact[email]"
                class="custom-footer__newsletter-input"
                placeholder="Enter your email address"
                required
              >
              <button type="submit" class="custom-footer__newsletter-btn">Sign up</button>
            {%- endform -%}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div
    class="custom-footer__bottom"
    style="--footer-bottom-bg: {{ section.settings.bottom_bg_color }}; --footer-bottom-text: {{ section.settings.bottom_text_color }};"
  >
    <div class="page-width">
      <div class="custom-footer__bottom-inner">
        <div class="custom-footer__bottom-links">
          {%- if section.settings.bottom_menu != blank -%}
            {%- for link in section.settings.bottom_menu.links -%}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          {%- else -%}
            <a href="/account/login">Sign In</a>
            <a href="/account/login">Forgot Password</a>
            <a href="/account">Your Orders</a>
            <a href="/apps/track-order">Order Tracking</a>
          {%- endif -%}
        </div>

        <div class="custom-footer__social">
          <span>Follow Us</span>
          <ul class="custom-footer__social-links">
            <li>
              <a href="#">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                </svg>
              </a>
            </li>
            <li>
              <a href="#">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 2C6.48 2 2 6.48 2 12c0 4.27 2.66 7.93 6.44 9.42-.09-.8-.16-2.04.03-2.9l1.17-4.96s-.29-.59-.29-1.46c0-1.37.8-2.39 1.78-2.39.84 0 1.52.61 1.52 1.34 0 .84-.54 2.1-.81 3.27-.23.98.5 1.78 1.46 1.78 1.76 0 3.12-1.85 3.12-4.53 0-2.38-1.72-4.04-4.16-4.04-2.82 0-4.48 2.12-4.48 4.31 0 .85.33 1.76.74 2.25.08.1.09.19.07.29l-.24 1s-.04.16-.16.14c-1.11-.52-1.81-2.18-1.81-3.52 0-2.86 2.08-5.5 6.02-5.5 3.17 0 5.63 2.26 5.63 5.28 0 3.14-1.98 5.68-4.73 5.68-1.15 0-2.22-.6-2.6-1.3l-.7 2.67c-.26.98-.95 2.2-1.41 2.95A9.98 9.98 0 0 0 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2z"></path>
                </svg>
              </a>
            </li>
            <li>
              <a href="#">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                </svg>
              </a>
            </li>
          </ul>
        </div>

        <div class="custom-footer__copyright">
          &copy; {{ section.settings.copyright_text }}
          {{ 'now' | date: '%Y' }} All rights reserved
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FBC117"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Typography Settings"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 14,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Heading Size (Desktop)",
      "default": 18
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 14,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Heading Size (Mobile)",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_size_desktop",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text Size (Desktop)",
      "default": 14
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text Size (Mobile)",
      "default": 14
    },
    {
      "type": "header",
      "content": "Contact Info"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Overlay Image (Woman)"
    },
    {
      "type": "header",
      "content": "Image Positioning"
    },
    {
      "type": "checkbox",
      "id": "img_center_auto",
      "label": "Center Image in Contact Column",
      "default": false
    },
    {
      "type": "range",
      "id": "img_left",
      "min": -100,
      "max": 100,
      "step": 2,
      "unit": "%",
      "label": "Left Position (Left/Right)",
      "default": -20
    },
    {
      "type": "range",
      "id": "img_top",
      "min": -100,
      "max": 100,
      "step": 2,
      "unit": "%",
      "label": "Top Position (Up/Down)",
      "default": -10
    },
    {
      "type": "range",
      "id": "img_width",
      "min": 200,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Image Width",
      "default": 350
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact Heading",
      "default": "Get in touch"
    },
    {
      "type": "text",
      "id": "timing_1",
      "label": "Timing Line 1",
      "default": "Mon-Sat: 8:30am-9:00pm"
    },
    {
      "type": "text",
      "id": "timing_2",
      "label": "Timing Line 2",
      "default": "Sunday: 10:00am-6:00pm"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number",
      "default": "+971 50 597 4531"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "24 22nd St - Al Qouz Ind.Fourth - Al Quoz\nDubai - United Arab Emirates"
    },
    {
      "type": "header",
      "content": "Menus"
    },
    {
      "type": "text",
      "id": "menu_heading_1",
      "label": "Menu 1 Heading",
      "default": "Products"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu 1"
    },
    {
      "type": "text",
      "id": "menu_heading_2",
      "label": "Menu 2 Heading",
      "default": "Help"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu 2"
    },
    {
      "type": "text",
      "id": "menu_heading_3",
      "label": "Menu 3 Heading",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Menu 3"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "For the latest offers and inspiration sign up below"
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "color",
      "id": "bottom_bg_color",
      "label": "Bottom Bar Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bottom_text_color",
      "label": "Bottom Bar Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "link_list",
      "id": "bottom_menu",
      "label": "Bottom Menu (Sign in, etc.)"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Cheap blinds"
    }
  ],
  "blocks": [
    {
      "type": "payment_image",
      "name": "Payment Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Payment Image (WebP/PNG)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}

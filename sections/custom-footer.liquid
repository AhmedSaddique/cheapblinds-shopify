{{ 'custom-footer.css' | asset_url | stylesheet_tag }}

<footer class="custom-footer" style="--footer-bg-color: {{ section.settings.bg_color }}; --footer-text-color: {{ section.settings.text_color }};">
  <div class="page-width">
    
    <div class="custom-footer__top">
      <div class="custom-footer__contact">
        {%- if section.settings.image != blank -%}
          <div class="custom-footer__contact-img-wrap">
             {{ section.settings.image | image_url: width: 400 | image_tag: loading: 'lazy' }}
          </div>
        {%- endif -%}
        
        <div class="custom-footer__contact-content">
          {%- if section.settings.contact_heading != blank -%}
            <h3>{{ section.settings.contact_heading }}</h3>
          {%- endif -%}
          
          {%- if section.settings.timing_1 != blank or section.settings.timing_2 != blank -%}
            <div class="custom-footer__contact-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
              <div>
                {%- if section.settings.timing_1 != blank -%}<div>{{ section.settings.timing_1 }}</div>{%- endif -%}
                {%- if section.settings.timing_2 != blank -%}<div>{{ section.settings.timing_2 }}</div>{%- endif -%}
              </div>
            </div>
          {%- endif -%}
          
          {%- if section.settings.phone != blank -%}
            <div class="custom-footer__contact-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              <div>{{ section.settings.phone }}</div>
            </div>
          {%- endif -%}
          
          {%- if section.settings.address != blank -%}
            <div class="custom-footer__contact-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              <div>{{ section.settings.address }}</div>
            </div>
          {%- endif -%}
        </div>
      </div>
      
      <div class="custom-footer__menus">
        {%- for i in (1..3) -%}
          {%- capture menu_setting -%}menu_{{ i }}{%- endcapture -%}
          {%- capture menu_heading_setting -%}menu_heading_{{ i }}{%- endcapture -%}
          
          {%- assign menu = section.settings[menu_setting] -%}
          {%- assign heading = section.settings[menu_heading_setting] -%}
          
          {%- if menu != blank or heading != blank -%}
            <div class="custom-footer__menu-col">
              {%- if heading != blank -%}
                <h3>{{ heading }}</h3>
              {%- endif -%}
              {%- if menu != blank -%}
                <ul>
                  {%- for link in menu.links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
    
    <div class="custom-footer__mid">
      <div class="custom-footer__payment">
        <div class="custom-footer__payment-title">Choose Your Payment Method</div>
        <div class="custom-footer__payment-icons">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
          {%- endfor -%}
        </div>
      </div>
      
      <div class="custom-footer__newsletter">
        <div class="custom-footer__newsletter-title">{{ section.settings.newsletter_heading }}</div>
        {%- form 'customer', class: 'custom-footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" name="contact[email]" class="custom-footer__newsletter-input" placeholder="Enter your email address" required>
          <button type="submit" class="custom-footer__newsletter-btn">Sign up</button>
        {%- endform -%}
      </div>
    </div>
    
  </div>
  
  <div class="custom-footer__bottom" style="--footer-bottom-bg: {{ section.settings.bottom_bg_color }}; --footer-bottom-text: {{ section.settings.bottom_text_color }};">
    <div class="page-width">
      <div class="custom-footer__bottom-inner">
        <div class="custom-footer__bottom-links">
          {%- if section.settings.bottom_menu != blank -%}
            {%- for link in section.settings.bottom_menu.links -%}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          {%- endif -%}
        </div>
        
        <div class="custom-footer__copyright">
           &copy; {{ section.settings.copyright_text }} {{ 'now' | date: "%Y" }} All rights reserved
        </div>
        
        <div class="custom-footer__social">
          <span>Follow Us</span>
          {%- render 'social-icons', class: 'custom-footer__social-links' -%}
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FBC117"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Contact Info"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Overlay Image (Woman)"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact Heading",
      "default": "Get in touch"
    },
    {
      "type": "text",
      "id": "timing_1",
      "label": "Timing Line 1",
      "default": "Mon-Sat: 8:30am-9:00pm"
    },
    {
      "type": "text",
      "id": "timing_2",
      "label": "Timing Line 2",
      "default": "Sunday: 10:00am-6:00pm"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number",
      "default": "+971 50 597 4531"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "24 22nd St - Al Qouz Ind.Fourth - Al Quoz\nDubai - United Arab Emirates"
    },
    {
      "type": "header",
      "content": "Menus"
    },
    {
      "type": "text",
      "id": "menu_heading_1",
      "label": "Menu 1 Heading",
      "default": "Products"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu 1"
    },
    {
      "type": "text",
      "id": "menu_heading_2",
      "label": "Menu 2 Heading",
      "default": "Help"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu 2"
    },
    {
      "type": "text",
      "id": "menu_heading_3",
      "label": "Menu 3 Heading",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Menu 3"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "For the latest offers and inspiration sign up below"
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "color",
      "id": "bottom_bg_color",
      "label": "Bottom Bar Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bottom_text_color",
      "label": "Bottom Bar Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "link_list",
      "id": "bottom_menu",
      "label": "Bottom Menu (Sign in, etc.)"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Cheap blinds"
    }
  ],
  "presets": [
    {
      "name": "Custom Footer"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}

<!-- sections/info-text-blocks.liquid -->

<style>
  .info-text {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: #fff;
  }

  .info-text__inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .info-text__block {
    margin-bottom: 50px;
  }

  .info-text__block:last-child {
    margin-bottom: 0;
  }

  .info-text__heading {
    font-size: 24px;
    font-weight: 600;
    color: #000;
    margin: 0 0 20px;
    line-height: 1.2;
  }

  .info-text__content {
    font-size: 14px;
    line-height: 1.8;
    color: #000;
  }

  .info-text__content p {
    margin-bottom: 20px;
  }

  .info-text__content p:last-child {
    margin-bottom: 0;
  }

  .info-text__content a {
    color: #FEBD0B;
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.3s ease;
  }

  .info-text__content a:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  @media screen and (max-width: 749px) {
    .info-text__heading {
      font-size: 20px;
    }

    .info-text__content {
      font-size: 14px;
    }

    .info-text__block {
      margin-bottom: 35px;
    }
  }
</style>

<div class="info-text">
  <div class="page-width">
    {%- for block in section.blocks -%}
      <div class="info-text__block" {{ block.shopify_attributes }}>
        {%- if block.settings.heading != blank -%}
          <h2 class="info-text__heading">{{ block.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if block.settings.content != blank -%}
          <div class="info-text__content rte">
            {{ block.settings.content }}
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "SEO & Info Text",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "info_block",
      "name": "Heading + Text Block",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Premium Blinds for Windows Across the UAE"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>At Cheap Blinds, we specialise in providing high-quality, made-to-measure window blinds at prices that genuinely surprise in the best possible way. Every blind is custom-crafted to your exact measurements, delivering a flawless fit that off-the-shelf products simply cannot match, no gaps, no guesswork, no compromise.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SEO & Info Text",
      "blocks": [
        {
          "type": "info_block"
        },
        {
          "type": "info_block",
          "settings": {
            "heading": "Blinds Made Easy — From Dubai to Fujairah",
            "content": "<p>Shopping for window blinds online has never been easier, and we've designed the entire <a href='https://cheapblinds.ae'>cheapblinds.ae</a> experience with that in mind.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

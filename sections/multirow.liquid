{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding bg-white overflow-hidden">
  <div class="page-width">
    <div class="flex flex-col gap-20 md:gap-32">
      {% for block in section.blocks %}
        <div
          class="flex flex-col md:flex-row items-center gap-12 md:gap-24 {% if block.settings.layout == 'image_first' %}md:flex-row-reverse{% endif %}"
          {{ block.shopify_attributes }}
        >
          <!-- Text Content (50%) -->
          <div class="w-full md:w-1/2 flex flex-col justify-center">
            {% if block.settings.heading != blank %}
              <h2 class="text-3xl md:text-4xl font-extrabold text-black mb-6 leading-[1.1]">
                {{ block.settings.heading }}
              </h2>
            {% endif %}

            {% if block.settings.text != blank %}
              <div class="mb-8">
                {{ block.settings.text }}
              </div>
            {% endif %}

            {% if block.settings.button_label != blank %}
              <div>
                <a
                  href="{{ block.settings.button_link }}"
                  class="inline-block bg-primary text-black font-bold py-3 px-10 rounded-full"
                >
                  {{ block.settings.button_label }}
                </a>
              </div>
            {% endif %}
          </div>

          <!-- Image Content (50% with constrained size) -->
          <div class="w-full md:w-1/2 flex justify-center">
            <div class="w-full aspect-[4/3] rounded-2xl overflow-hidden">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | img_url: '600x' }}"
                  alt="{{ block.settings.image.alt | escape }}"
                  class="w-full h-full object-cover"
                  loading="lazy"
                >
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'w-full h-full bg-gray-100' }}
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Multirow Custom",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "layout",
          "label": "Desktop Image Placement",
          "options": [
            { "value": "text_first", "label": "Image on Right" },
            { "value": "image_first", "label": "Image on Left" }
          ],
          "default": "text_first"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Multirow Custom",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "heading": "High Quality Blinds at Prices You'll Love",
            "text": "<p>Perfectly fitted blinds don't just improve the look, they enhance comfort too. Our easy measuring guides help you get accurate results, so your blinds sit exactly as they should. Quality is at the core of everything we do.</p>",
            "layout": "text_first"
          }
        },
        {
          "type": "row",
          "settings": {
            "heading": "Here to Help, Every Step of the Way",
            "text": "<p>Questions, ideas, or need a second opinion? Our friendly team is always ready to assist. From choosing the right style to placing your order, support is just a message away.</p>",
            "button_label": "Contact Us",
            "layout": "text_first"
          }
        }
      ]
    }
  ]
}
{% endschema %}

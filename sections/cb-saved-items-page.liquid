{{ 'wishlist.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'cb-product-grid.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign page_type = section.settings.page_type
  assign is_wishlist = false
  if page_type == 'wishlist'
    assign is_wishlist = true
  endif
-%}

<div
  class="cb-saved-items section-{{ section.id }}-padding"
  data-same-day-icon="{{ 'icon-same-day.svg' | asset_url }}"
>
  <div class="page-width">
    <div class="cb-saved-items__header">
      <p class="cb-saved-items__count" id="{% if is_wishlist %}WishlistPageCount{% else %}SamplesPageCount{% endif %}">
        0 Item(s)
      </p>
      <h1 class="cb-saved-items__title">
        {% if is_wishlist %}
          {{ section.settings.wishlist_heading }}
        {% else %}
          {{ section.settings.samples_heading }}
        {% endif %}
      </h1>
    </div>

    <div
      class="cb-saved-items__empty"
      id="{% if is_wishlist %}WishlistPageEmpty{% else %}SamplesPageEmpty{% endif %}"
    >
      <p class="cb-saved-items__empty-text">
        {% if is_wishlist %}
          {{ section.settings.wishlist_empty_text }}
        {% else %}
          {{ section.settings.samples_empty_text }}
        {% endif %}
      </p>
      <a href="{{ routes.all_products_collection_url }}" class="cb-saved-items__continue">
        {{ section.settings.continue_label }}
      </a>
    </div>

    <div
      class="cb-saved-items__grid {% unless is_wishlist %}cb-saved-items__grid--samples{% endunless %}"
      id="{% if is_wishlist %}WishlistPageGrid{% else %}SamplesPageGrid{% endif %}"
    ></div>
  </div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "CB Wishlist Samples",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "page_type",
      "label": "Page type",
      "default": "wishlist",
      "options": [
        { "value": "wishlist", "label": "Wishlist" },
        { "value": "samples", "label": "Free Samples" }
      ]
    },
    {
      "type": "text",
      "id": "wishlist_heading",
      "label": "Wishlist heading",
      "default": "My Wishlist"
    },
    {
      "type": "text",
      "id": "samples_heading",
      "label": "Free samples heading",
      "default": "My Free Samples"
    },
    {
      "type": "text",
      "id": "wishlist_empty_text",
      "label": "Wishlist empty text",
      "default": "Your wishlist is currently empty."
    },
    {
      "type": "text",
      "id": "samples_empty_text",
      "label": "Free samples empty text",
      "default": "You have no free samples selected yet."
    },
    {
      "type": "text",
      "id": "continue_label",
      "label": "Continue button label",
      "default": "Continue shopping"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Wishlist Page"
    },
    {
      "name": "Free Samples Page"
    }
  ]
}
{% endschema %}

<!-- sections/google-reviews.liquid -->

<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<style>
  .google-reviews-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: #fff;
    overflow: hidden;
  }

  .google-reviews__inner {
    display: flex;
    align-items: center;
    gap: 30px;
    position: relative;
  }

  .google-reviews__summary {
    flex: 0 0 350px;
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .google-reviews__header {
    display: flex;
    gap: 15px;
    margin-bottom: 10px;
  }

  .google-reviews__logo img {
    max-width: 90px;
    height: auto;
    display: block;
  }

  .google-reviews__title {
    font-size: 20px;
    font-weight: 800;
    line-height: 1.1;
    margin: 0;
    color: #000;
  }

  .google-reviews__rating-stack {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .google-reviews__stars-large {
    color: #FEB907;
    font-size: 32px;
    letter-spacing: 2px;
    line-height: 1;
  }

  .google-reviews__count {
    margin-bottom: 15px;
  }

  .google-reviews__btn {
    display: inline-block;
    background-color: #FEB907;
    color: #000;
    padding: 2px 6px;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    border: 1.5px solid #000;
    transition: all 0.3s ease;
    white-space: nowrap;
    width: fit-content;
  }

  /* --- SLIDER AREA --- */
  .google-reviews__slider-wrapper {
    flex: 1;
    position: relative;
    min-width: 0;
  }

  .google-reviews__swiper {
    width: 100%;
    padding: 20px 5px 40px !important;
  }

  .google-reviews__card {
    background: #fff;
    border-radius: 12px;
    padding: 25px;
    box-shadow: 0px 7px 0px -1px rgba(31, 27, 27, 0.2);
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 15px;
    border: 1px solid rgba(0,0,0,0.04); /* Very subtle border */
    margin: 10px 0px 10px 0px !important;
  }

  .google-reviews__user-row {
    display: flex;
    align-items: center;
    gap: 12px;
    position: relative;
    padding-right: 25px; /* Space for Google Icon */
  }

  .google-reviews__avatar {
    width: 55px;
    height: 55px;
    border-radius: 50%;
    overflow: hidden;
    flex: 0 0 55px;
  }

  .google-reviews__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .google-reviews__user-info {
    flex: 1;
  }

  .google-reviews__user-name {
    font-size: 16px;
    font-weight: 700;
    color: #000;
    display: block;
    line-height: 1.2;
  }

  .google-reviews__date {
    font-size: 12px;
    color: #999;
    display: block;
    margin-top: 2px;
  }

  .google-reviews__google-icon {
    width: 22px;
    height: 22px;
    position: absolute;
    top: 10px;
    right: 0;
  }

  .google-reviews__stars-small {
    color: #FEB907;
    font-size: 24px;
    letter-spacing: 1px;
    line-height: 1;
  }

  .google-reviews__text {
    font-size: 14px;
    margin: 0;
  }

  .google-nav-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 30px;
    height: 30px;
    background: #FEB907;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    border: none;
    color: #000;
    transition: all 0.2s ease;
  }

  .google-nav-arrow:hover {
       background: #ffffff;
       border: 1px solid #000;

  }

  /* Desktop Arrow Positions */
  .google-nav-arrow.prev { left: 0; }
  .google-nav-arrow.next { right: 0; }

     .google-reviews__pagination {
     position: absolute !important;
     bottom: 0px !important; /* Positions it within the padding-bottom of the swiper */
     left: 0 !important;
     width: 100% !important;
     display: flex !important;
     justify-content: center !important;
     align-items: center;
     gap: 8px;
     z-index: 10;
     pointer-events: none; /* Allows clicks to pass through the container to the bullets */
   }

  .swiper-pagination-bullet {
     width: 24px !important;
     height: 12px !important;
     background-color: transparent !important;
     border: 1px solid #ccc !important;
     border-radius: 20px !important;
     opacity: 1 !important;
     margin: 0 !important;
     transition: all 0.3s ease;
     cursor: pointer;
     pointer-events: auto; /* Makes bullets clickable again */
   }

   .swiper-pagination-bullet-active {
     background-color: #FEB907 !important;
     width: 45px !important; /* Active dot is longer */
   }

  /* MOBILE RESPONSIVE */
  @media screen and (max-width: 989px) {
    .google-reviews__inner {
      flex-direction: column;
      gap: 20px;
    }
    .google-reviews__summary {
      flex: none;
      width: 100%;
      align-items: center;
      padding-left: 0;
      text-align: center;
    }
    .google-reviews__slider-wrapper {
        width: 100%;
        padding-right: 0;
        padding-top: 57px;
        position: relative;
        top: -92px;
    }

    .google-reviews__header {
      justify-content: center;
      flex-wrap: wrap;
    }
    .google-reviews__rating-stack {
      padding-left: 0;
      display: flex;
      align-items: center;
    }

    /* Move navigation arrows above the slider in mobile */
    .google-nav-arrow {
      top: 30px; /* Positioned above the card */
      transform: none;
    }
    .google-nav-arrow.prev { left: 10px; }
    .google-nav-arrow.next { right: 10px; }
  }
</style>

<div class="google-reviews-section">
  <div class="page-width">
    <div class="google-reviews__inner">
      <!-- Summary Block -->
      <div class="google-reviews__summary">
        <div class="google-reviews__header">
          <div class="google-reviews__logo">
            {% if section.settings.logo != blank %}
              {{ section.settings.logo | image_url: width: 200 | image_tag: loading: 'lazy' }}
            {% else %}
              <h2 class="h1">{{ shop.name }}</h2>
            {% endif %}
          </div>
          <div>
            <h2 class="google-reviews__title">{{ section.settings.title }}</h2>
            <div class="google-reviews__rating-stack">
              <div class="google-reviews__stars-large">★★★★★</div>
              <span class="google-reviews__count">({{ section.settings.review_count }} reviews)</span>
              <a href="{{ section.settings.write_link | default: '#' }}" target="_blank" class="google-reviews__btn">
                Write a reviews
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Slider Block -->
      <div class="google-reviews__slider-wrapper">
        <!-- Navigation Arrows -->
        <button class="google-nav-arrow prev swiper-button-prev-{{ section.id }}">
          <svg width="20" height="14" viewBox="0 0 20 14" xmlns="http://www.w3.org/2000/svg">
            <path d="M7.60251 0.0554848C7.84961 0.137402 8.11801 0.436396 8.1734 0.690336C8.22452 0.919702 8.19896 1.09582 8.08819 1.30471C8.04559 1.38253 6.92939 2.4884 5.60443 3.7622L3.1931 6.07633L11.2749 6.09681L19.361 6.11729L19.5527 6.21969C19.6549 6.27703 19.7998 6.404 19.8722 6.4982C19.9872 6.66203 20 6.70709 20 6.99789C20 7.28869 19.9872 7.33375 19.8722 7.49758C19.7998 7.59178 19.6549 7.71875 19.5527 7.7761L19.361 7.87849L11.2749 7.89897L3.1931 7.91945L5.62573 10.2541C7.26595 11.831 8.08393 12.6419 8.13931 12.7525C8.34807 13.1785 8.15209 13.6986 7.7005 13.9239C7.50453 14.0181 7.12962 14.0263 6.90808 13.9403C6.69081 13.8502 0.202366 7.62045 0.0830765 7.3829C-0.0276909 7.16582 -0.0276909 6.82996 0.0830765 6.61288C0.13846 6.4982 1.2504 5.40462 3.47854 3.2666C6.34999 0.514216 6.81862 0.084156 6.96773 0.0431976C7.19779 -0.01824 7.3895 -0.0141439 7.60251 0.0554848Z" fill="#151515"/>
          </svg>
        </button>
        <button class="google-nav-arrow next swiper-button-next-{{ section.id }}">
          <svg width="20" height="14" viewBox="0 0 20 14" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.3975 0.0554848C12.1504 0.137402 11.882 0.436396 11.8266 0.690336C11.7755 0.919702 11.801 1.09582 11.9118 1.30471C11.9544 1.38253 13.0706 2.4884 14.3956 3.7622L16.8069 6.07633L8.7251 6.09681L0.639046 6.11729L0.447332 6.21969C0.345085 6.27703 0.200234 6.404 0.127809 6.4982C0.0127809 6.66203 0 6.70709 0 6.99789C0 7.28869 0.0127809 7.33375 0.127809 7.49758C0.200234 7.59178 0.345085 7.71875 0.447332 7.7761L0.639046 7.87849L8.7251 7.89897L16.8069 7.91945L14.3743 10.2541C12.734 11.831 11.9161 12.6419 11.8607 12.7525C11.6519 13.1785 11.8479 13.6986 12.2995 13.9239C12.4955 14.0181 12.8704 14.0263 13.0919 13.9403C13.3092 13.8502 19.7976 7.62045 19.9169 7.3829C20.0277 7.16582 20.0277 6.82996 19.9169 6.61288C19.8615 6.4982 18.7496 5.40462 16.5215 3.2666C13.65 0.514216 13.1814 0.084156 13.0323 0.0431976C12.8022 -0.01824 12.6105 -0.0141439 12.3975 0.0554848Z" fill="#151515"/>
          </svg>
        </button>

        <div class="swiper google-reviews__swiper swiper-{{ section.id }}">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              <div class="swiper-slide">
                <div class="google-reviews__card">
                  <div class="google-reviews__user-row">
                    <div class="google-reviews__avatar">
                      {% if block.settings.avatar != blank %}
                        {{ block.settings.avatar | image_url: width: 110 | image_tag: loading: 'lazy' }}
                      {% else %}
                        <div style="width:100%;height:100%;background:#eee;"></div>
                      {% endif %}
                    </div>
                    <div class="google-reviews__user-info">
                      <span class="google-reviews__user-name">{{ block.settings.user_name }}</span>
                      <span class="google-reviews__date">{{ block.settings.date }}</span>
                    </div>
                    <div class="google-reviews__google-icon">
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                      </svg>
                    </div>
                  </div>
                  <div class="google-reviews__stars-small">★★★★★</div>
                  <p class="google-reviews__text">{{ block.settings.review_text | escape }}</p>
                </div>
              </div>
            {% endfor %}
          </div>
          <!-- Pagination dots visible in your mobile screenshot -->
          <div class="swiper-pagination google-reviews__pagination swiper-pagination-{{ section.id }}"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    new Swiper('.swiper-{{ section.id }}', {
      loop: true,
      spaceBetween: 20,
      slidesPerView: 1,
      observer: true,
      observeParents: true,
      navigation: {
        nextEl: '.swiper-button-next-{{ section.id }}',
        prevEl: '.swiper-button-prev-{{ section.id }}',
      },
      pagination: {
        el: '.swiper-pagination-{{ section.id }}',
        clickable: true,
      },
      breakpoints: {
        750: { slidesPerView: 2.2 },
        1280: { slidesPerView: 3 },
      },
    });
  });
</script>

{% schema %}
{
  "name": "Google Reviews Slider",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "text", "id": "title", "label": "Title", "default": "Google Reviews from Our Customers" },
    { "type": "text", "id": "review_count", "label": "Review Count", "default": "84,290" },
    { "type": "url", "id": "write_link", "label": "Review Link" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "image_picker", "id": "avatar", "label": "Avatar" },
        { "type": "text", "id": "user_name", "label": "Name", "default": "Customer Name" },
        { "type": "text", "id": "date", "label": "Date", "default": "Jan 24, 2026" },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review",
          "default": "I love this product because the support is great."
        }
      ]
    }
  ],
  "presets": [
    { "name": "Google Reviews Slider", "blocks": [{ "type": "review" }, { "type": "review" }, { "type": "review" }] }
  ]
}
{% endschema %}

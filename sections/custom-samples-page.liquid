{{ 'custom-samples-page.css' | asset_url | stylesheet_tag }}

<section class="cb-samples-page">
  <div class="page-width">
    <h1 class="cb-samples-page__title">Your Samples Basket</h1>

    <div class="cb-samples-page__layout">
      <div>
        <div class="cb-samples-page__banner">
          <span class="cb-samples-page__banner-text">Unlimited Samples - Free of Charge</span>
        </div>

        <div id="SamplesPageList" class="cb-samples-page__grid">
          <a
            href="{{ section.settings.browse_link | default: routes.all_products_collection_url }}"
            class="cb-samples-card cb-samples-card--addmore samples-page-add-card"
          >
            <div class="cb-samples-card__plus-serrated swatch-pinked" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </div>
            <div class="cb-samples-card__title">Add more samples</div>
          </a>
        </div>

        <div id="SamplesPageEmpty" class="cb-samples-page__empty hidden">
          <p class="cb-samples-page__empty-text">No free samples selected yet.</p>
          <a
            href="{{ section.settings.browse_link | default: routes.all_products_collection_url }}"
            class="cb-samples-page__cta"
          >
            Browse products
          </a>
        </div>

        <div class="cb-samples-page__note">
          All sample orders received before 4:00 pm Mon-Fri will be dispatched the same day by
          <strong>First Class Post free of charge.</strong>
        </div>
      </div>

      <aside class="cb-samples-sidebar">
        <h2 class="cb-samples-sidebar__heading">Free sample checkout</h2>

        <div class="cb-samples-form" aria-live="polite">
          <div class="cb-samples-summary">
            <div class="cb-samples-summary__row">
              <span>Items</span>
              <strong id="SamplesSummaryCount">0</strong>
            </div>
            <div class="cb-samples-summary__row">
              <span>Total</span>
              <strong id="SamplesSummaryTotal">{{ 0 | money }}</strong>
            </div>
            <div class="cb-samples-summary__row">
              <span>Shipping</span>
              <strong>{{ 0 | money }}</strong>
            </div>
          </div>

          <p id="SamplesCheckoutError" class="cb-samples-error"></p>

          <button type="button" class="cb-samples-submit" id="SamplesCheckoutBtn">
            Checkout free samples
          </button>

          <p class="cb-samples-page__note" style="margin-top: 12px;">
            Checkout will include only your free sample items. Your normal cart items are restored if you come back from checkout.
          </p>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const listContainer = document.getElementById('SamplesPageList');
    const emptyState = document.getElementById('SamplesPageEmpty');
    const storageKey = 'cb-samples';
    const maxSamples = 5;
    const ZERO_MONEY = {{ 0 | money | json }};
    const DISCOUNT_CODES_RAW = {{ section.settings.checkout_discount_code | default: 'FREE100, SHIPFREE' | strip | json }};

    const parseDiscountCodes = () => {
      const raw = String(DISCOUNT_CODES_RAW || '');
      if (!raw) return [];
      return raw
        .split(',')
        .map((c) => c.trim())
        .filter(Boolean);
    };

    const buildDiscountUrl = (code, redirectTo) => {
      const root = window?.Shopify?.routes?.root || '/';
      const rootWithSlash = root.endsWith('/') ? root : `${root}/`;
      const redirectPath = String(redirectTo || '').startsWith('/')
        ? `${rootWithSlash}${String(redirectTo || '').replace(/^\//, '')}`
        : String(redirectTo || '');
      // Shopify discount permalinks work most reliably with relative redirects (not absolute URLs).
      return `${rootWithSlash}discount/${encodeURIComponent(String(code || '').trim())}?redirect=${encodeURIComponent(redirectPath)}`;
    };

    const checkoutBtn = document.getElementById('SamplesCheckoutBtn');
    const summaryCount = document.getElementById('SamplesSummaryCount');
    const summaryTotal = document.getElementById('SamplesSummaryTotal');
    const checkoutError = document.getElementById('SamplesCheckoutError');

    const normalizeImageUrl = (url) => {
      const value = String(url || '').trim();
      if (!value) return '';
      if (value.startsWith('//')) return `https:${value}`;
      return value;
    };

    const buildFabricVisual = (item) => {
      const swatchImage = normalizeImageUrl(item.swatchImage || item.image);
      const colorValue = String(item.color || '').trim();

      if (colorValue && colorValue !== 'null' && colorValue !== 'undefined') {
        const safeColor = colorValue.includes('#') ? colorValue : `#${colorValue}`;
        return `<div class="cb-color-swatch swatch-pinked" style="background-color:${safeColor};"></div>`;
      }

      if (swatchImage) {
        return `<div class="cb-product-swatch-large swatch-pinked" style="background-image:url('${swatchImage}');"></div>`;
      }

      return `<div class="cb-product-swatch-large swatch-pinked"></div>`;
    };

    const setError = (message) => {
      if (!checkoutError) return;
      checkoutError.textContent = message || '';
      checkoutError.classList.toggle('is-visible', !!message);
    };

    const getSampleItems = () => {
      try {
        const data = localStorage.getItem(storageKey);
        const items = data ? JSON.parse(data) : [];
        return Array.isArray(items) ? items : [];
      } catch (_) {
        return [];
      }
    };

    const fetchFirstVariantIdForHandle = async (handle) => {
      const root = window?.Shopify?.routes?.root || '/';
      const rootWithSlash = root.endsWith('/') ? root : `${root}/`;
      const url = `${rootWithSlash}products/${encodeURIComponent(handle)}.js`;
      const product = await fetch(url, { headers: { Accept: 'application/json' } }).then((r) =>
        r.ok ? r.json() : null
      );

      const first = product?.variants?.[0]?.id;
      return first ? String(first) : '';
    };

    const buildCheckoutCartItems = async (items) => {
      const counts = new Map();

      for (const item of items) {
        let id = String(item?.variantId || item?.variant_id || '').trim();
        if (!id && item?.handle) {
          try {
            id = await fetchFirstVariantIdForHandle(item.handle);
          } catch (_) {
            // ignore
          }
        }

        if (!id) continue;
        counts.set(id, (counts.get(id) || 0) + 1);
      }

      return [...counts.entries()].map(([id, quantity]) => ({ id: Number(id), quantity }));
    };

    const clearCart = async () => {
      await fetch('/cart/clear.js', {
        method: 'POST',
        headers: { Accept: 'application/json', 'Content-Type': 'application/json' },
      });
    };

    const addToCart = async (items) => {
      const res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { Accept: 'application/json', 'Content-Type': 'application/json' },
        body: JSON.stringify({ items }),
      });

      if (!res.ok) {
        const text = await res.text();
        throw new Error(text || 'Failed to add items to cart');
      }
    };

    const backupCart = async () => {
      const cart = await fetch('/cart.js', { headers: { Accept: 'application/json' } }).then((r) =>
        r.ok ? r.json() : null
      );

      const backup = {
        createdAt: Date.now(),
        items:
          cart?.items?.map((item) => ({
            id: item.id,
            quantity: item.quantity,
            properties: item.properties || undefined,
          })) || [],
      };

      localStorage.setItem('cb-cart-backup', JSON.stringify(backup));
      return backup;
    };

    const restoreBackupCart = async (backup) => {
      if (!backup || !Array.isArray(backup.items)) return;
      await clearCart();
      if (backup.items.length > 0) {
        await addToCart(
          backup.items.map((it) => ({
            id: it.id,
            quantity: it.quantity,
            properties: it.properties,
          }))
        );
      }
    };

    const startSamplesCheckout = async () => {
      const samples = getSampleItems();
      if (samples.length === 0) {
        setError('Your samples basket is empty. Please add at least 1 sample.');
        return;
      }

      const checkoutItems = await buildCheckoutCartItems(samples);
      if (checkoutItems.length === 0) {
        setError('Could not prepare your samples for checkout. Please re-add the samples and try again.');
        return;
      }

      let backup = null;
      const discountCodes = parseDiscountCodes();

      try {
        backup = await backupCart();
        localStorage.setItem('cb-cart-restore', '1');

        // Prepare multi-step flow for discount application (done via storefront redirects).
        if (discountCodes.length > 0) {
          localStorage.setItem(
            'cb-samples-checkout-flow',
            JSON.stringify({ codes: discountCodes, step: 0, startedAt: Date.now() })
          );
        } else {
          localStorage.removeItem('cb-samples-checkout-flow');
        }

        await clearCart();
        await addToCart(checkoutItems);

        if (discountCodes.length === 0) {
          window.location.href = '/checkout';
          return;
        }

        // Apply the first code and redirect to cart, where samples-checkout-flow.js will apply remaining codes and go to checkout.
        // This avoids unreliable multi-code query params and avoids nested /discount redirects that can bounce to home.
        window.location.href = buildDiscountUrl(discountCodes[0], '/cart');
      } catch (e) {
        try {
          if (backup) {
            await restoreBackupCart(backup);
          }
        } catch (_) {
          // ignore
        }

        localStorage.removeItem('cb-cart-restore');
        localStorage.removeItem('cb-samples-checkout-flow');
        setError('Something went wrong starting checkout. Please try again.');
      }
    };

    function renderPageSamples() {
      if (!listContainer) return;

      listContainer.querySelectorAll('.sample-page-item').forEach((el) => el.remove());

      const items = getSampleItems();

      emptyState.classList.toggle('hidden', items.length > 0);

      if (summaryCount) summaryCount.textContent = String(items.length);
      if (summaryTotal) summaryTotal.textContent = ZERO_MONEY;
      setError('');

      items.forEach((item) => {
        const card = document.createElement('div');
        card.className = 'sample-page-item cb-samples-card';
        card.innerHTML = `
          <a href="${item.url}" class="cb-samples-card__visual" aria-label="${item.title}">
            ${buildFabricVisual(item)}
          </a>
          <a href="${item.url}" class="cb-samples-card__title">
            ${item.title}
          </a>
          <button class="remove-btn cb-samples-card__remove" data-handle="${
            item.handle
          }" aria-label="Remove sample">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 9V18" stroke="#AA9157" stroke-width="1.7" stroke-linecap="round"/>
                <path d="M16 9V18" stroke="#AA9157" stroke-width="1.7" stroke-linecap="round"/>
                <path d="M5 6H19" stroke="#AA9157" stroke-width="1.7" stroke-linecap="round"/>
                <path d="M10 4H14" stroke="#AA9157" stroke-width="1.7" stroke-linecap="round"/>
                <path d="M7 6L8 20H16L17 6" stroke="#AA9157" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
          </button>
        `;
        listContainer.insertBefore(card, listContainer.lastElementChild);
      });

      const addMoreCard = listContainer.querySelector('.samples-page-add-card');
      if (addMoreCard) {
        addMoreCard.classList.toggle('hidden', items.length >= maxSamples);
      }
    }

    document.addEventListener('click', (e) => {
      const removeBtn = e.target.closest('.remove-btn');
      if (removeBtn) {
        const handle = removeBtn.dataset.handle;
        let items = getSampleItems();
        items = items.filter((entry) => entry.handle !== handle);
        localStorage.setItem(storageKey, JSON.stringify(items));

        renderPageSamples();
        if (window.FreeSamplesService) {
          window.FreeSamplesService.items = items;
          window.FreeSamplesService.updateUI();
        }
      }
    });

    if (checkoutBtn) {
      checkoutBtn.addEventListener('click', async () => {
        if (checkoutBtn.disabled) return;
        setError('');

        const originalText = checkoutBtn.textContent;
        checkoutBtn.disabled = true;
        checkoutBtn.textContent = 'Starting checkout...';

        try {
          await startSamplesCheckout();
        } finally {
          // If we navigated away, this won't matter. If not, restore UI.
          checkoutBtn.disabled = false;
          checkoutBtn.textContent = originalText;
        }
      });
    }

    renderPageSamples();

    // `samples.js` initializes `window.FreeSamplesService` on `DOMContentLoaded` too and may
    // hydrate older saved entries (adding missing `image/url/title`). Re-render once that
    // hydration has had a chance to complete so swatches/images show correctly.
    const rerenderAfterSamplesHydration = async () => {
      const service = window.FreeSamplesService;
      if (!service) return;

      try {
        const maybePromise = service?.hydrateMissingItemFields?.();
        if (maybePromise && typeof maybePromise.then === 'function') {
          await maybePromise;
        } else if (service.isHydrating) {
          const start = Date.now();
          while (service.isHydrating && Date.now() - start < 1500) {
            // Wait briefly for hydration to finish.
            // eslint-disable-next-line no-await-in-loop
            await new Promise((resolve) => setTimeout(resolve, 50));
          }
        }
      } catch (e) {
        // No-op: the page can still render from whatever data is available.
      }

      renderPageSamples();
    };

    setTimeout(() => {
      rerenderAfterSamplesHydration();
    }, 0);
  });
</script>

{% schema %}
{
  "name": "Samples Page",
  "settings": [
    {
      "type": "url",
      "id": "browse_link",
      "label": "Add More Samples Link",
      "info": "Link for the 'Add more samples' card and empty state button."
    },
    {
      "type": "text",
      "id": "checkout_discount_code",
      "label": "Checkout discount code (optional)",
      "default": "FREE100, SHIPFREE",
      "info": "Optional. Comma-separated discount codes to auto-apply for sample checkout only (e.g. FREE100, SHIPFREE)."
    },
    {
      "type": "url",
      "id": "success_redirect_url",
      "label": "Success Redirect URL",
      "info": "Where to redirect after clicking 'Order Free Sample'"
    }
  ]
}
{% endschema %}

<!-- sections/video-text-banner.liquid -->

<style>
    .video-text-banner {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .video-text-banner__container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      background-color: {{ section.settings.bg_color }};
      overflow: hidden;
      border-radius: {{ section.settings.border_radius }}px;
      min-height: 600px;
    }

    .video-text-banner__content {
      padding: 20px 40px; /* Reduced padding to allow larger graphic */
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
    }

    .video-text-banner__video {
      position: relative;
      min-height: 600px; /* Match the container's min-height */
      background: #000;
    }

    .video-text-banner__video video,
    .video-text-banner__video iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .video-text-banner__sticker img {
      width: 100%;
      height: auto;
      display: block;
    }

    .video-text-banner__sticker {
      width: 100%;
      margin-bottom: 20px;
    }

  .video-text-banner__button {
      background-color: #FEB907;
      color: #000;
      padding: 8px 25px;
      border-radius: 8px;
      font-weight: 600;
      text-decoration: none;
      transition: transform 0.3s ease, opacity 0.3s ease;
      display: inline-block;
  }

    .video-text-banner__button:hover {
      transform: scale(1.05);
      opacity: 0.9;
    }

    /* Responsive: Video First on Mobile */
    @media screen and (max-width: 749px) {
      .video-text-banner__container {
        grid-template-columns: 1fr;
        min-height: auto;
      }

      .video-text-banner__video {
        grid-row: 1; /* Force video to top */
        aspect-ratio: 16 / 9;
        min-height: auto;
      }

      .video-text-banner__content {
        grid-row: 2;
        padding: 40px 20px;
        align-items: center;
        text-align: center;
      }

      .video-text-banner {
        padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
        padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
      }
    }
</style>

<div class="video-text-banner">
  <div class="page-width">
    <div class="video-text-banner__container">
      <!-- Text/Graphic Side -->
      <div class="video-text-banner__content" style="background-color: {{ section.settings.bg_color }};">
        {%- if section.settings.sticker_image != blank -%}
          <div class="video-text-banner__sticker">
            {{
              section.settings.sticker_image
              | image_url: width: 1000
              | image_tag: loading: 'lazy', class: 'sticker-img'
            }}
          </div>
        {%- endif -%}

        {%- if section.settings.btn_text != blank -%}
          <a href="{{ section.settings.btn_link | default: '#' }}" class="video-text-banner__button">
            {{ section.settings.btn_text | escape }}
          </a>
        {%- endif -%}
      </div>

      <!-- Video Side -->
      <div class="video-text-banner__video">
        {%- if section.settings.video != blank -%}
          {{
            section.settings.video
            | video_tag:
              autoplay: true,
              loop: true,
              muted: true,
              controls: false,
              playsinline: true,
              class: 'video-element'
          }}
        {%- elsif section.settings.video_url != blank -%}
          {%- if section.settings.video_url.type == 'youtube' -%}
            <iframe
              src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ section.settings.video_url.id }}&controls=0&modestbranding=1&rel=0"
              frameborder="0"
              allow="autoplay; encrypted-media"
              allowfullscreen
            ></iframe>
          {%- elsif section.settings.video_url.type == 'vimeo' -%}
            <iframe
              src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=1&muted=1&loop=1&background=1"
              frameborder="0"
              allow="autoplay; fullscreen"
              allowfullscreen
            ></iframe>
          {%- endif -%}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Video + Text Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Left Content Background",
      "default": "#FEF9E7"
    },
    {
      "type": "image_picker",
      "id": "sticker_image",
      "label": "Main Content Image (Text/Sticker)"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Label",
      "default": "Explore More"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button Color",
      "default": "#FFC107"
    },
    {
      "type": "header",
      "content": "Video Settings"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify-hosted video",
      "info": "Recommended for best performance."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "label": "External video URL",
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Video + Text Banner"
    }
  ]
}
{% endschema %}

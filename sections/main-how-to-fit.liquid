{{ 'how-to-fit.css' | asset_url | stylesheet_tag }}

<div class="htf-section" id="how-to-fit-section" data-section-id="{{ section.id }}">
  <!-- Desktop Tabs (Top Level) -->
  <div class="htf-tabs htf-hide-mobile">
    {% assign top_tab_index = 0 %}
    {% for block in section.blocks %}
      {% if block.type == 'top_tab' %}
        <button
          type="button"
          class="htf-tab-btn {% if top_tab_index == 0 %}htf-tab-active{% endif %}"
          data-top-tab="{{ top_tab_index }}"
          onclick="htfSwitchTopTab({{ top_tab_index }})"
          {{ block.shopify_attributes }}
        >
          {{ block.settings.title }}
        </button>
        {% assign top_tab_index = top_tab_index | plus: 1 %}
      {% endif %}
    {% endfor %}
  </div>

  <!-- Mobile Tabs (Scrollable) -->
  <div class="htf-tabs-mobile-wrapper htf-hide-desktop">
    <div class="htf-tabs-scroll-area">
      <div class="htf-tabs-mobile">
        {% assign top_tab_index = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'top_tab' %}
            <button
              type="button"
              class="htf-tab-btn {% if top_tab_index == 0 %}htf-tab-active{% endif %}"
              data-top-tab="{{ top_tab_index }}"
              onclick="htfSwitchTopTab({{ top_tab_index }})"
            >
              {{ block.settings.title }}
            </button>
            {% assign top_tab_index = top_tab_index | plus: 1 %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="htf-content-area page-width">
    {% assign top_tab_index = -1 %}
    {% assign sub_tab_index = -1 %}
    {% assign inside_top_tab = false %}
    {% assign inside_sub_tab = false %}

    {% for block in section.blocks %}
      {% if block.type == 'top_tab' %}
        <!-- Close previous structures -->
        {% if inside_sub_tab %}
          </div>
          <!-- close prev sub tab content -->
          {% assign inside_sub_tab = false %}
        {% endif %}
        {% if inside_top_tab %}
          </div>
          <!-- close sub tab wrapper -->
          </div>
          <!-- close top tab content -->
        {% endif %}

        {% assign top_tab_index = top_tab_index | plus: 1 %}
        {% assign sub_tab_index = -1 %}
        {% assign inside_top_tab = true %}

        <div
          class="htf-tab-content {% if top_tab_index == 0 %}htf-content-active{% endif %}"
          data-top-content="{{ top_tab_index }}"
        >
          <!-- Banner Layout -->
          <div class="htf-banner-layout">
            <div class="htf-text-column">
              {% if block.settings.subtitle != blank %}
                <div class="htf-subtitle-pill">{{ block.settings.subtitle }}</div>
              {% endif %}

              <h1 class="htf-heading">
                {% if block.settings.heading_black != blank %}
                  <span class="htf-heading-black">{{ block.settings.heading_black }}</span>
                {% endif %}
                {% if block.settings.heading_yellow != blank %}
                  <br>
                  <span class="htf-heading-yellow">{{ block.settings.heading_yellow }}</span>
                {% endif %}
              </h1>

              {% if block.settings.description != blank %}
                <div class="htf-description">
                  {{ block.settings.description }}
                </div>
              {% endif %}

              {% if block.settings.pdf_url != blank %}
                <a
                  href="{{ block.settings.pdf_url }}"
                  class="htf-download-btn"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg
                    class="htf-download-icon"
                    viewBox="0 0 24 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path d="M12 15L12 3M12 15L8 11M12 15L16 11M21 21H3" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  Download PDF
                </a>
              {% endif %}
            </div>

            <div class="htf-media-column">
              <div class="htf-media-wrapper">
                {% if block.settings.video %}
                  {{
                    block.settings.video
                    | video_tag: class: 'htf-video-element', image_size: '800x', controls: false
                  }}
                  <div class="htf-play-overlay">
                    <button
                      type="button"
                      class="htf-play-btn"
                      aria-label="Play video"
                      onclick="htfToggleVideo(this)"
                    >
                      <svg viewBox="0 0 24 24" fill="#fff" xmlns="http://www.w3.org/2000/svg">
                        <path d="M8 5V19L19 12L8 5Z"/>
                      </svg>
                    </button>
                  </div>
                {% elsif block.settings.image %}
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag: class: 'htf-image-element', loading: 'lazy'
                  }}
                {% else %}
                  <div style="background:#f4f4f4; width:100%; height:100%; display:flex; align-items:center; justify-content:center; min-height:300px;">
                    <span style="color: #666">Image/Video Placeholder</span>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>

          <!--
            JavaScript will inject Sub Tabs into this container dynamically based on structural hierarchy
          -->
          <div class="htf-sub-tabs-wrapper js-sub-tabs-container-{{ top_tab_index }}">
            <!-- Sub tabs injected here automatically -->
          </div>

          <div class="htf-sub-content-wrapper">
      {% elsif block.type == 'sub_tab' %}
        {% if inside_sub_tab %}
          </div>
          <!-- close prev sub tab content -->
        {% endif %}

        {% assign sub_tab_index = sub_tab_index | plus: 1 %}
        {% assign inside_sub_tab = true %}

        <div
          class="htf-sub-content {% if sub_tab_index == 0 %}htf-sub-content-active{% endif %}"
          data-sub-content="{{ top_tab_index }}-{{ sub_tab_index }}"
          data-sub-title="{{ block.settings.title | escape }}"
          {{ block.shopify_attributes }}
        >
          <div class="htf-section-title-wrap">
            <h2 class="htf-section-title">{{ block.settings.title }}</h2>
          </div>

          <!-- Parts Grid -->
      {% elsif block.type == 'parts_grid' %}
        <div class="htf-2col-grid htf-card" {{ block.shopify_attributes }} style="border: none;">
          <div class="htf-parts-left">
            <h3 class="htf-block-title">{{ block.settings.title_left }}</h3>
            <div class="htf-parts-wrapper">
              {% if block.settings.image_left %}
                {{ block.settings.image_left | image_url: width: 600 | image_tag: loading: 'lazy' }}
              {% endif %}
            </div>
          </div>
          <div class="htf-parts-right">
            <h3 class="htf-block-title">{{ block.settings.title_right }}</h3>
            <div class="htf-subcard-grid">
              {% if block.settings.part_1_name != blank %}
                <div class="htf-sub-card">
                  {% if block.settings.part_1_image -%}
                    {{-
                      block.settings.part_1_image
                      | image_url: width: 80
                      | image_tag: loading: 'lazy'
                    -}}
                  {%- endif %}
                  <span>{{ block.settings.part_1_name }}</span>
                </div>
              {% endif %}
              {% if block.settings.part_2_name != blank %}
                <div class="htf-sub-card">
                  {% if block.settings.part_2_image -%}
                    {{-
                      block.settings.part_2_image
                      | image_url: width: 80
                      | image_tag: loading: 'lazy'
                    -}}
                  {%- endif %}
                  <span>{{ block.settings.part_2_name }}</span>
                </div>
              {% endif %}
              {% if block.settings.part_3_name != blank %}
                <div class="htf-sub-card">
                  {% if block.settings.part_3_image -%}
                    {{-
                      block.settings.part_3_image
                      | image_url: width: 80
                      | image_tag: loading: 'lazy'
                    -}}
                  {%- endif %}
                  <span>{{ block.settings.part_3_name }}</span>
                </div>
              {% endif %}
              {% if block.settings.part_4_name != blank %}
                <div class="htf-sub-card">
                  {% if block.settings.part_4_image -%}
                    {{-
                      block.settings.part_4_image
                      | image_url: width: 80
                      | image_tag: loading: 'lazy'
                    -}}
                  {%- endif %}
                  <span>{{ block.settings.part_4_name }}</span>
                </div>
              {% endif %}
            </div>
          </div>
        </div>

        <!-- Tools Grid -->
      {% elsif block.type == 'tools_grid' %}
        <div class="htf-tools-section" {{ block.shopify_attributes }}>
          <h3 class="htf-section-title">{{ block.settings.title }}</h3>
          <div class="htf-tools-grid">
            {% for i in (1..8) %}
              {% capture t_name_key %}tool_{{ i }}_name{% endcapture %}
              {% capture t_icon_key %}tool_{{ i }}_icon{% endcapture %}
              {% assign t_name = block.settings[t_name_key] %}
              {% assign t_icon = block.settings[t_icon_key] %}

              {% if t_name != blank %}
                <div class="htf-tool-card">
                  <div class="htf-tool-icon-wrapper">
                    {% if t_icon %}
                      {{
                        t_icon
                        | image_url: width: 60
                        | image_tag:
                          loading: 'lazy',
                          style: 'width: 40px; height: 40px; object-fit: contain;'
                      }}
                    {% else %}
                      {% assign tl = t_name | downcase %}
                      {% if tl contains 'pencil' %}
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M12 19L21.5 9.5C22.3284 8.67157 22.3284 7.32843 21.5 6.5L17.5 2.5C16.6716 1.67157 15.3284 1.67157 14.5 2.5L5 12V19H12ZM5 19H2" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      {% elsif tl contains 'screw' %}
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M14.5 9.5L9.5 14.5M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      {% elsif tl contains 'drill' %}
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M14 11V16H10V11H6L12 2L18 11H14ZM10 16V22H14V16H10Z" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      {% elsif tl contains 'tape' %}
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M3 12H21M3 8H21M6 16V12M10 16V12M14 16V12M18 16V12M5 4H19C20.1046 4 21 4.89543 21 6V18C21 19.1046 20.1046 20 19 20H5C3.89543 20 3 19.1046 3 18V6C3 4.89543 3.89543 4 5 4Z" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      {% else %}
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="12" cy="12" r="9" stroke="#000" stroke-width="2"/><path d="M12 8V12L15 15" stroke="#000" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                      {% endif %}
                    {% endif %}
                  </div>
                  <span class="htf-tool-name">{{ t_name }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <!-- Step Card -->
      {% elsif block.type == 'step_card' %}
        <div
          class="htf-card htf-step-container {% if block.settings.reverse_layout %}htf-step-reverse{% endif %}"
          style="margin-bottom: 30px"
          {{ block.shopify_attributes }}
        >
          <div class="htf-step-text-area">
            <span class="htf-step-number">{{ block.settings.step_number }}</span>
            <div class="htf-step-header">
              <h3 class="htf-step-title">{{ block.settings.title }}</h3>

              {% if block.settings.description != blank %}
                <div class="htf-step-desc">
                  {{ block.settings.description }}
                </div>
              {% endif %}
              {% if block.settings.toggles != blank %}
                <div class="htf-step-toggles">
                  {% assign toggles = block.settings.toggles | split: ',' %}
                  {% for t in toggles %}
                    <button class="htf-step-toggle-btn">
                      {{ t | strip }}
                    </button>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </div>
          <div class="htf-step-img-area">
            {% if block.settings.image %}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {% else %}
              <div style="width: 100%; height: 200px; background: #fdfdfd; border: 1px dashed #ccc; display:flex; align-items:center; justify-content:center;">
                Image Placeholder
              </div>
            {% endif %}
          </div>
        </div>

        <!-- Child Safety Box -->
      {% elsif block.type == 'child_safety' %}
        <div class="htf-section-title-wrap" style="margin-top: 30px">
          <h2 class="htf-section-title">
            {{ block.settings.main_title | default: 'Child Safety' }}
          </h2>
        </div>
        <div class="htf-safety-box" {{ block.shopify_attributes }}>
          <div class="htf-safety-flex">
            <div class="htf-safety-text">
              <div class="htf-safety-row">
                <div class="htf-safety-icon-box">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-width="2"/>
                    <path d="M12 8V12L14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                </div>
                <div>
                  <h3 class="htf-safety-heading">{{ block.settings.heading }}</h3>
                  <p class="htf-safety-p">{{ block.settings.description }}</p>
                </div>
              </div>
              <div class="htf-safety-alert">
                <h4>
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    style="vertical-align: text-bottom; margin-right: 4px;"
                  >
                    <path d="M12 2L1 21H23L12 2Z" fill="#ffca28"/>
                    <path d="M11 10V15H13V10H11ZM11 17V19H13V17H11Z" fill="#333"/>
                  </svg>
                  {{ block.settings.alert_title }}
                </h4>
                <p class="htf-safety-p">{{ block.settings.alert_description }}</p>
              </div>
            </div>
            <div class="htf-step-img-area">
              {% if block.settings.image %}
                {{ block.settings.image | image_url: width: 500 | image_tag: loading: 'lazy' }}
              {% endif %}
            </div>
          </div>
        </div>

        <!-- Removing Blind -->
      {% elsif block.type == 'removing_blind' %}
        <div class="htf-section-title-wrap">
          <h2 class="htf-section-title">
            {{ block.settings.title | default: 'Removing the Blind' }}
          </h2>
        </div>
        <div
          class="htf-card htf-step-container"
          style="margin-bottom: 50px"
          {{ block.shopify_attributes }}
        >
          <div class="htf-step-img-area">
            {% if block.settings.image %}
              {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy' }}
            {% endif %}
          </div>
          <div class="htf-remove-text-area">
            <h3 class="htf-step-title" style="margin-bottom:15px">
              {{ block.settings.step_title }}
            </h3>
            <div class="htf-step-desc">
              {{ block.settings.description }}
            </div>
          </div>
        </div>

        <!-- Bottom Warnings -->
      {% elsif block.type == 'bottom_warnings' %}
        <div class="htf-section-title-wrap">
          <h2 class="htf-section-title">
            {{ block.settings.main_title | default: 'Cleaning Instructions' }}
          </h2>
        </div>
        <div class="htf-2col-grid" {{ block.shopify_attributes }}>
          <div class="htf-light-card" style="border-radius: 20px;">
            <div class="htf-tool-icon-wrapper" style="background:#fff9e6">
              {% if block.settings.icon_left %}
                {{
                  block.settings.icon_left
                  | image_url: width: 60
                  | image_tag:
                    loading: 'lazy',
                    style: 'width: 24px; height: 24px; object-fit: contain;'
                }}
              {% else %}
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  width="24"
                  height="24"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="#ffb803" stroke-width="2"/><path d="M8 12L11 15L16 9" stroke="#ffb803" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {% endif %}
            </div>
            <p>{{ block.settings.warning_text_left }}</p>
          </div>
          <div class="htf-warning-alert">
            <h4>
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d="M12 2L1 21H23L12 2Z" fill="#ffca28"/>
                <path d="M11 10V15H13V10H11ZM11 17V19H13V17H11Z" fill="#333"/>
              </svg>
              {{ block.settings.warning_title_right }}
            </h4>
            <p>{{ block.settings.warning_text_right }}</p>
          </div>
        </div>
      {% endif %}
    {% endfor %}

    <!-- Close any remaining open tags -->
    {% if inside_sub_tab %}
      </div>
      <!-- close htf-sub-content -->
    {% endif %}
    {% if inside_top_tab %}
      </div>
      <!-- close wrapper -->
      </div>
      <!-- close htf-tab-content -->
    {% endif %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('how-to-fit-section');
    if (!section) return;

    // Dynamically build the sub-tabs from the data populated inside `.htf-sub-content`
    const topContents = section.querySelectorAll('.htf-tab-content');

    topContents.forEach((topContent, topIndex) => {
      const subTabsContainer = topContent.querySelector(`.js-sub-tabs-container-${topIndex}`);
      const subContents = topContent.querySelectorAll('.htf-sub-content');

      if (subContents.length > 0 && subTabsContainer) {
        subContents.forEach((sub, subIndex) => {
          const title = sub.getAttribute('data-sub-title');
          const btn = document.createElement('button');
          btn.className = `htf-sub-tab-btn ${subIndex === 0 ? 'htf-sub-tab-active' : ''}`;
          btn.textContent = title;
          btn.onclick = () => {
            // Activate logic for sub tabs
            subTabsContainer.querySelectorAll('.htf-sub-tab-btn').forEach((b, i) => {
              if (i === subIndex) b.classList.add('htf-sub-tab-active');
              else b.classList.remove('htf-sub-tab-active');
            });
            subContents.forEach((sc, i) => {
              if (i === subIndex) sc.classList.add('htf-sub-content-active');
              else sc.classList.remove('htf-sub-content-active');
            });
          };
          subTabsContainer.appendChild(btn);
        });
      }
    });

    const videos = document.querySelectorAll('.htf-video-element');
    videos.forEach((vid) => {
      vid.addEventListener('click', function () {
        const overlay = this.closest('.htf-media-wrapper').querySelector('.htf-play-overlay');
        if (!this.paused) {
          this.pause();
          if (overlay) overlay.style.display = 'flex';
        } else {
          this.play();
          if (overlay) overlay.style.display = 'none';
        }
      });
      vid.addEventListener('ended', function () {
        const overlay = this.closest('.htf-media-wrapper').querySelector('.htf-play-overlay');
        if (overlay) overlay.style.display = 'flex';
      });
    });
  });

  function htfSwitchTopTab(index) {
    const section = document.getElementById('how-to-fit-section');

    // Switch Top Buttons
    const btns = section.querySelectorAll('.htf-tab-btn');
    btns.forEach((btn) => {
      if (parseInt(btn.getAttribute('data-top-tab')) === index) {
        btn.classList.add('htf-tab-active');
        btn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      } else {
        btn.classList.remove('htf-tab-active');
      }
    });

    // Switch Top Content
    const contents = section.querySelectorAll('.htf-tab-content');
    contents.forEach((content) => {
      if (parseInt(content.getAttribute('data-top-content')) === index) {
        content.classList.add('htf-content-active');
      } else {
        content.classList.remove('htf-content-active');
        // Pause any playing videos
        const vid = content.querySelector('.htf-video-element');
        if (vid && !vid.paused) {
          vid.pause();
          const overlay = content.querySelector('.htf-play-overlay');
          if (overlay) overlay.style.display = 'flex';
        }
      }
    });
  }

  function htfToggleVideo(btn) {
    const wrapper = btn.closest('.htf-media-wrapper');
    const video = wrapper.querySelector('.htf-video-element');
    const overlay = wrapper.querySelector('.htf-play-overlay');

    if (video) {
      if (video.paused) {
        video.play();
        overlay.style.display = 'none';
      } else {
        video.pause();
        overlay.style.display = 'flex';
      }
    }
  }
</script>

{% schema %}
{
  "name": "How to Fit Guides",
  "settings": [],
  "blocks": [
    {
      "type": "top_tab",
      "name": "Top Tab (Category)",
      "settings": [
        { "type": "text", "id": "title", "label": "Tab Title", "default": "Roller Blinds" },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle Pill",
          "default": "Fitting Instructions"
        },
        { "type": "text", "id": "heading_black", "label": "Black Heading" },
        { "type": "text", "id": "heading_yellow", "label": "Yellow Heading" },
        { "type": "richtext", "id": "description", "label": "Description" },
        { "type": "url", "id": "pdf_url", "label": "PDF Download Link" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "video", "id": "video", "label": "Shopify Video" }
      ]
    },
    {
      "type": "sub_tab",
      "name": "Inner Sub Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Inner Tab Title",
          "default": "Roman Blinds Classic"
        }
      ]
    },
    {
      "type": "parts_grid",
      "name": "Cleaning / Parts Grid",
      "settings": [
        {
          "type": "text",
          "id": "title_left",
          "label": "Left Title",
          "default": "Cleaning Instructions"
        },
        { "type": "image_picker", "id": "image_left", "label": "Left Diagram" },
        {
          "type": "text",
          "id": "title_right",
          "label": "Right Title",
          "default": "Parts Identified"
        },
        { "type": "text", "id": "part_1_name", "label": "Part 1 Name", "default": "Screws" },
        { "type": "image_picker", "id": "part_1_image", "label": "Part 1 Image" },
        { "type": "text", "id": "part_2_name", "label": "Part 2 Name", "default": "Brackets" },
        { "type": "image_picker", "id": "part_2_image", "label": "Part 2 Image" },
        { "type": "text", "id": "part_3_name", "label": "Part 3 Name" },

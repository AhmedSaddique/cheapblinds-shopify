<style>
  .cb-header-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 15px;
    padding-bottom: 15px;
    background-color: #ffffff;
    border-bottom: 2px solid #f0f0f0;
    gap: 10px;
  }
  .cb-logo-container img {
    max-width: {{ section.settings.logo_width }}px;
    height: auto;
  }
  .cb-logo-text {
    font-size: 32px;
    font-weight: 800;
    color: #000;
    text-decoration: none;
    line-height: 1;
  }
  .cb-search-container {
    flex-grow: 1;
    max-width: 650px;
    margin: 0 auto;
    width: 100%;
    position: relative;
  }
  .cb-predictive-search {
    display: block;
    width: 100%;
    position: relative;
  }
  .cb-search-form {
    display: block;
    position: relative;
    margin: 0;
  }
  .cb-search-input-wrapper {
    display: flex;
    position: relative;
    border: 1px solid #999;
    border-radius: 30px;
    background: #fff;
    overflow: hidden;
  }
  .cb-search-input {
    width: 100%;
    padding: 12px 20px 12px 45px;
    border: none;
    outline: none;
    font-size: 16px;
    background: transparent;
  }
  .cb-search-icon {
    position: absolute;
    left: 15px;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    opacity: 0.6;
    z-index: 2;
  }
  .cb-icons-container {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .cb-icon-link {
    color: #000;
    text-decoration: none;
    display: flex;
    align-items: center;
    position: relative;
    padding-left: 10px;
    width: 32px;
  }
  .cb-icon-link:not(:first-child) {
    border-left: 1px solid #000;
  }
  .cb-icon-link svg {
    width: 22px;
    height: 22px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
  }
  .cb-cart-icon svg {
     fill: #fff;
  }
  .cb-cart-count {
    position: absolute;
    top: -2px;
    right: -10px;
    background-color: #000;
    color: #fff;
    font-size: 11px;
    border-radius: 50%;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
  }

  #shopify-section-{{ section.id }} {
    position: relative;
    z-index: 1000;
  }

  /* Hide complete section on mobile to prevent white space */
  @media (max-width: 1024px) {
    #shopify-section-{{ section.id }} {
      display: none !important;
    }
  }
</style>

<div class="cb-header-main page-width">
  <div class="cb-logo-container">
    <a href="/" class="cb-logo-link">
      {% if section.settings.logo != blank %}
        <img
          src="{{ section.settings.logo | img_url: 'master' }}"
          alt="{{ shop.name }}"
          width="{{ section.settings.logo.width }}"
          height="{{ section.settings.logo.height }}"
        >
      {% else %}
        <span class="cb-logo-text">{{ shop.name }}</span>
      {% endif %}
    </a>
  </div>

  <div class="cb-search-container">
    {%- if settings.predictive_search_enabled -%}
      <predictive-search
        class="cb-predictive-search"
        data-loading-text="{{ 'accessibility.loading' | t }}"
      >
    {%- else -%}
      <search-form class="cb-predictive-search">
    {%- endif -%}
    <form action="{{ routes.search_url }}" method="get" role="search" class="cb-search-form">
      <div class="cb-search-input-wrapper">
        <svg class="cb-search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
        <input
          type="search"
          name="q"
          id="Search-In-Main"
          placeholder="{{ section.settings.search_placeholder }}"
          class="cb-search-input"
          value="{{ search.terms | escape }}"
          {%- if settings.predictive_search_enabled -%}
            role="combobox"
            aria-expanded="false"
            aria-owns="predictive-search-results"
            aria-controls="predictive-search-results"
            aria-haspopup="listbox"
            aria-autocomplete="list"
            autocorrect="off"
            autocomplete="off"
            autocapitalize="off"
            spellcheck="false"
          {%- endif -%}
        >
        <input type="hidden" name="type" value="product">
        <input type="hidden" name="options[prefix]" value="last">
        <button type="reset" class="visually-hidden">Reset</button>
        <button type="submit" class="visually-hidden">Search</button>
      </div>

      {%- if settings.predictive_search_enabled -%}
        <div
          class="predictive-search predictive-search--header"
          tabindex="-1"
          data-predictive-search
          style="position: absolute; top: calc(100% + 5px); left: 0; width: 100%; z-index: 100; background: #fff; border-radius: 12px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); border: 1px solid #e0e0e0;"
        >
          {%- render 'loading-spinner', class: 'predictive-search__loading-state' -%}
        </div>
        <span
          class="predictive-search-status visually-hidden"
          role="status"
          aria-hidden="true"
        ></span>
      {%- endif -%}
    </form>
    {%- if settings.predictive_search_enabled -%}
      </predictive-search>
    {%- else -%}
      </search-form>
    {%- endif -%}
  </div>

  <div class="cb-icons-container">
    {% if shop.customer_accounts_enabled %}
      <a href="{{ routes.account_url }}" class="cb-icon-link">
        {% if section.settings.account_icon != blank %}
          <img
            src="{{ section.settings.account_icon | img_url: '40x' }}"
            alt="Account"
            width="22"
            height="22"
            style="object-fit: contain;"
          >
        {% else %}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
        {% endif %}
      </a>
    {% endif %}

    <a href="#" class="cb-icon-link" id="wishlist-icon-bubble">
      {% if section.settings.wishlist_icon != blank %}
        <img
          src="{{ section.settings.wishlist_icon | img_url: '40x' }}"
          alt="Wishlist"
          width="22"
          height="22"
          style="object-fit: contain;"
        >
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path style="fill:#000;stroke:none;" d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
      {% endif %}
      <span class="cb-cart-count hide wishlist-counter-element">
        <span aria-hidden="true">0</span>
      </span>
    </a>

    <a href="#" class="cb-icon-link" id="samples-icon-bubble">
      {% if section.settings.samples_icon != blank %}
        <img
          src="{{ section.settings.samples_icon | img_url: '40x' }}"
          alt="Samples"
          width="22"
          height="22"
          style="object-fit: contain;"
        >
      {% else %}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><path d="M12 2v20"/><path d="M16 2v20"/>
        </svg>
      {% endif %}
      <span class="cb-cart-count hide samples-counter-element" id="samples-counter-desktop">
        <span aria-hidden="true">0</span>
      </span>
    </a>

    <a href="{{ routes.cart_url }}" class="cb-icon-link cb-cart-icon" id="cb-cart-icon-bubble">
      {% if section.settings.cart_icon != blank %}
        <img
          src="{{ section.settings.cart_icon | img_url: '40x' }}"
          alt="Cart"
          width="20"
          height="20"
          style="object-fit: contain;"
        >
      {% else %}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          stroke="none"
        >
          <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1.003 1.003 0 0 0 20 4H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
        </svg>
      {% endif %}
      <span
        class="cb-cart-count {% if cart.item_count == 0 %}hidden{% endif %}"
        id="cb-cart-count-badge"
      >
        {{ cart.item_count }}
      </span>
    </a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var badge = document.getElementById('cb-cart-count-badge');
    if (!badge) return;

    function updateCartBadge(count) {
      count = parseInt(count, 10) || 0;
      badge.textContent = count;
      if (count > 0) {
        badge.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
      }
    }

    // Shopify always re-renders #cart-icon-bubble (in header.liquid, hidden on
    // desktop) after every cart change. Watch it and mirror the count.
    var cartBubble = document.getElementById('cart-icon-bubble');
    if (cartBubble) {
      var observer = new MutationObserver(function () {
        var countEl = cartBubble.querySelector('.cart-count-bubble [aria-hidden="true"]');
        updateCartBadge(countEl ? countEl.textContent.trim() : 0);
      });
      observer.observe(cartBubble, { childList: true, subtree: true, characterData: true });
    }

    // Pubsub fallback — fires on quantity change / remove from cart drawer.
    if (typeof subscribe !== 'undefined' && typeof PUB_SUB_EVENTS !== 'undefined') {
      subscribe(PUB_SUB_EVENTS.cartUpdate, function (event) {
        if (event && event.cartData && typeof event.cartData.item_count !== 'undefined') {
          updateCartBadge(event.cartData.item_count);
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "CB Main Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 170,
      "unit": "px",
      "label": "Custom logo width"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder text",
      "default": "Search"
    },
    {
      "type": "header",
      "content": "Right side Icons"
    },
    {
      "type": "image_picker",
      "id": "account_icon",
      "label": "Account Icon (optional)"
    },
    {
      "type": "image_picker",
      "id": "wishlist_icon",
      "label": "Wishlist Icon (optional)"
    },
    {
      "type": "image_picker",
      "id": "samples_icon",
      "label": "Samples Icon (optional)"
    },
    {
      "type": "image_picker",
      "id": "cart_icon",
      "label": "Cart Icon (optional)"
    }
  ],
  "presets": [
    {
      "name": "CB Main Header",
      "category": "Header"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}

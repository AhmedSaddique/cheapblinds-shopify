{% comment %}
  Custom Cart Section for Cheap Blinds
  Unified Basket and Summary Sidebar
{% endcomment %}

{{ 'cb-cart.css' | asset_url | stylesheet_tag }}
{{ 'custom-product-main.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>

<script>
  // Global Modal Functions
  window.openCpmModal = function (id) {
    var modal = document.getElementById(id);
    if (modal) {
      modal.classList.remove('cpm-modal-hidden');
      document.body.style.overflow = 'hidden';
    }
  };

  window.closeCpmModal = function (id) {
    var modal = document.getElementById(id);
    if (modal) {
      modal.classList.add('cpm-modal-hidden');
      document.body.style.overflow = 'auto'; // restore scroll
    }
  };

  // Close modal when clicking on overlay background
  document.addEventListener('click', function (e) {
    if (e.target.classList.contains('cpm-modal-overlay')) {
      window.closeCpmModal(e.target.id);
    }
  });
</script>

<div class="cb-cart page-width" id="main-cart-items" data-id="{{ section.id }}">
  <div class="cb-cart__layout js-contents">
    {%- if cart != empty -%}
      <div class="cb-cart__basket">
        <h1 class="cb-cart__title">Your Shopping Basket</h1>
        <!-- Basket Header -->
        <div class="cb-cart__basket-header">
          <span>{{ 'sections.cart.headings.product' | t }}</span>
          <span class="text-center">{{ 'sections.cart.headings.quantity' | t }}</span>
          <span class="text-right">Unit price</span>
        </div>

        <cart-items>
          <div class="cb-cart__items-list">
            {%- for item in cart.items -%}
              <div class="cb-cart__item" id="CartItem-{{ item.index | plus: 1 }}">
                <!-- Col 1: Product -->
                <div class="cb-cart__item-product">
                  <div class="cb-cart__item-image-wrapper">
                    {% if item.image %}
                      {{ item.image | image_url: width: 400 | image_tag: loading: 'lazy' }}
                    {% else %}
                      <div style="background-color: #f4f4f4; width: 100%; aspect-ratio: 1/1;"></div>
                    {% endif %}
                  </div>
                  <div class="cb-cart__item-details">
                    <div class="cb-cart__item-top">
                      <h2 class="cb-cart__item-title">
                        <a href="{{ item.url }}">Lindsay White Blackout Roller Blinds</a>
                      </h2>
                      <div class="cb-cart__item-props">
                        <div>41cm Width &times; 41cm Drop</div>
                        <div>Recess measurement</div>
                        <div>Standard brackets</div>
                      </div>
                    </div>
                    <!-- Motorised Option Selection (Form Toggleable) -->
                    <div class="cb-cart__option-selector">
                      <label class="cb-cart__option-item">
                        <input
                          type="radio"
                          name="motorised-{{ item.index }}"
                          value="without"
                          class="cb-cart__option-input visually-hidden"
                          checked
                        >
                        <div class="cb-cart__option-content">
                          <div class="cb-cart__option-selected-label">
                            <span class="cb-cart__option-selected-icon">✓</span>
                            Selected
                          </div>
                          <div class="cb-cart__option-radio">
                            <span class="cb-cart__option-radio-circle"></span>
                            Without Motorised
                          </div>
                          <div class="cb-cart__option-price cb-price-with-icon">
                            {{- 'icon-currency.svg' | inline_asset_content -}}
                            <span>315</span>
                          </div>
                        </div>
                      </label>
                      <label class="cb-cart__option-item">
                        <input
                          type="radio"
                          name="motorised-{{ item.index }}"
                          value="motorised"
                          class="cb-cart__option-input visually-hidden"
                        >
                        <div class="cb-cart__option-content">
                          <div class="cb-cart__option-selected-label">
                            <span class="cb-cart__option-selected-icon">✓</span>
                            Selected
                          </div>
                          <div class="cb-cart__option-radio">
                            <span class="cb-cart__option-radio-circle"></span>
                            Motorised <span class="cb-cart__option-tag">MOTORISED</span>
                          </div>
                          <div class="cb-cart__option-price cb-price-with-icon">
                            {{- 'icon-currency.svg' | inline_asset_content -}}
                            <span>365</span>
                          </div>
                        </div>
                      </label>
                    </div>
                  </div>
                </div>

                <!-- Mobile Header (Hidden on Desktop) -->
                <div class="cb-cart__mobile-header">
                  <span>Quantity</span>
                  <span>Unit price</span>
                  <span></span>
                </div>

                <!-- Col 2 & 3 Mobile Wrapper -->
                <div class="cb-cart__item-actions-wrapper">
                  <!-- Col 2: Quantity -->
                  <div class="cb-cart__item-quantity">
                    <div class="cb-cart__qty-selector">
                      <button
                        class="cb-cart__qty-btn minus"
                        name="minus"
                        type="button"
                        onclick="this.parentNode.querySelector('input').stepDown(); this.parentNode.querySelector('input').dispatchEvent(new Event('change', { bubbles: true }));"
                      >
                        -
                      </button>
                      <input
                        class="cb-cart__qty-input"
                        type="number"
                        name="updates[]"
                        value="50"
                        min="0"
                        data-index="{{ item.index | plus: 1 }}"
                        id="Quantity-{{ item.index | plus: 1 }}"
                      >
                      <button
                        class="cb-cart__qty-btn plus"
                        name="plus"
                        type="button"
                        onclick="this.parentNode.querySelector('input').stepUp(); this.parentNode.querySelector('input').dispatchEvent(new Event('change', { bubbles: true }));"
                      >
                        +
                      </button>
                    </div>
                  </div>

                  <!-- Col 3: Price & Trash -->
                  <div class="cb-cart__item-price">
                    <div class="cb-cart__price-box cb-price-with-icon">
                      {{- 'icon-currency.svg' | inline_asset_content -}}
                      <span>800</span>
                    </div>

                    <cart-remove-button
                      id="Remove-{{ item.index | plus: 1 }}"
                      data-index="{{ item.index | plus: 1 }}"
                    >
                      <a
                        href="{{ item.url_to_remove }}"
                        class="cb-cart__remove-btn"
                        aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"
                      >
                        {{- 'icon-delete-cart.svg' | inline_asset_content -}}
                      </a>
                    </cart-remove-button>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </cart-items>
      </div>

      <!-- Order Summary Sidebar -->
      <div>
        <h2 class="cb-cart__title">Order summary</h2>
        <aside class="cb-cart__summary" id="main-cart-footer" data-id="{{ section.id }}">
          <div class="js-contents cb-cart__summary-box">
            <div class="cb-cart__summary-row">
              <span>Subtotal</span>
              <span class="cb-price-with-icon">
                {{- 'icon-currency.svg' | inline_asset_content -}}
                <span>{{ cart.total_price | money_without_currency }}</span>
              </span>
            </div>

            <p class="cb-cart__summary-note">Shipping options will be updated during checkout.</p>

            <div class="cb-cart__summary-row cb-cart__summary-row--total">
              <span>Total</span>
              <span class="cb-price-with-icon">
                {{- 'icon-currency.svg' | inline_asset_content -}}
                <span>{{ cart.total_price | money_without_currency }}</span>
              </span>
            </div>

            <p class="cb-cart__safe-checkout">Prices are inclusive of VAT</p>

            <div class="cb-cart__safe-checkout">Payment Methods</div>

            <div class="cb-cart__payment-methods">
              {%- if section.settings.show_payment_icons -%}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'payment_icon' and block.settings.icon_image != blank -%}
                    <div class="cb-footer__payment-card">
                      <img
                        src="{{ block.settings.icon_image | image_url: width: 150 }}"
                        alt="{{ block.settings.icon_image.alt | default: 'Payment Icon' }}"
                        class="cb-cart__payment-icon"
                        style="height: {{ block.settings.icon_height }}px; width: auto; object-fit: contain;"
                        loading="lazy"
                        {{ block.shopify_attributes }}
                      >
                    </div>
                  {%- endif -%}
                {%- endfor -%}

                {%- if section.blocks.size == 0 -%}
                  <img
                    src="https://upload.wikimedia.org/wikipedia/commons/5/5e/Visa_Inc._logo.svg"
                    class="cb-cart__payment-icon"
                    alt="Visa"
                  >
                  <img
                    src="https://upload.wikimedia.org/wikipedia/commons/f/fa/Apple_logo_black.svg"
                    class="cb-cart__payment-icon"
                    alt="Apple Pay"
                    style="height:20px"
                  >
                  <img
                    src="https://upload.wikimedia.org/wikipedia/commons/b/b5/PayPal.svg"
                    class="cb-cart__payment-icon"
                    style="height:15px; margin-top:5px"
                    alt="PayPal"
                  >
                  <img
                    src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg"
                    class="cb-cart__payment-icon"
                    alt="Mastercard"
                  >
                {%- endif -%}
              {%- endif -%}
            </div>

            <div
              class="cb-cart__safe-checkout"
              style="margin-top:10px; margin-bottom:20px; font-weight:600; padding-top:15px"
            >
              Guaranteed Safe Checkout
            </div>

            <!-- Tabby Widget Placeholder -->
            <div class="cb-cart__installment">
              <div class="cb-cart__installment-logo">
                <img src="{{ 'tabby.png' | asset_url }}" alt="Tabby">
              </div>
              <p class="cb-cart__installment-text">
                Pay 4 interest-free payments of
                <span onclick="openCpmModal('tabbyModal')" style="cursor:pointer"
                  >Learn more...</span
                >
              </p>
              <div class="cb-cart__installment-table">
                {% assign installment_price = cart.total_price | divided_by: 4 %}
                <div class="cb-cart__installment-step">
                  <b
                    ><span class="cb-price-with-icon">
                      {{- 'icon-currency.svg' | inline_asset_content -}}
                      <span>{{ installment_price | money_without_currency }}</span></span
                    ></b
                  >Today
                </div>
                <div class="cb-cart__installment-step">
                  <b
                    ><span class="cb-price-with-icon">
                      {{- 'icon-currency.svg' | inline_asset_content -}}
                      <span>{{ installment_price | money_without_currency }}</span></span
                    ></b
                  >In 1 month
                </div>
                <div class="cb-cart__installment-step">
                  <b
                    ><span class="cb-price-with-icon">
                      {{- 'icon-currency.svg' | inline_asset_content -}}
                      <span>{{ installment_price | money_without_currency }}</span></span
                    ></b
                  >In 2 month
                </div>
                <div class="cb-cart__installment-step">
                  <b
                    ><span class="cb-price-with-icon">
                      {{- 'icon-currency.svg' | inline_asset_content -}}
                      <span>{{ installment_price | money_without_currency }}</span></span
                    ></b
                  >In 3 month
                </div>
              </div>
            </div>

            <!-- Tamara Widget Placeholder -->
            <div class="cb-cart__installment cb-cart__installment--tamara">
              <div class="cb-cart__installment-logo">
                <img src="{{ 'tamara.png' | asset_url }}" alt="Tamara">
              </div>
              <p class="cb-cart__installment-text">
                Pay 4 interest-free payments of
                <span onclick="openCpmModal('tamaraModal')" style="cursor:pointer"
                  >Learn more...</span
                >
              </p>
              <div class="cb-cart__installment-table">
                <div class="cb-cart__installment-step">
                  <b
                    ><span class="cb-price-with-icon">
                      {{- 'icon-currency.svg' | inline_asset_content -}}
                      <span>{{ installment_price | money_without_currency }}</span></span
                    ></b
                  >Today
                </div>
                <div class="cb-cart__installment-step">
                  <b
                    ><span class="cb-price-with-icon">
                      {{- 'icon-currency.svg' | inline_asset_content -}}
                      <span>{{ installment_price | money_without_currency }}</span></span
                    ></b
                  >In 1 month
                </div>
                <div class="cb-cart__installment-step">
                  <b
                    ><span class="cb-price-with-icon">
                      {{- 'icon-currency.svg' | inline_asset_content -}}
                      <span>{{ installment_price | money_without_currency }}</span></span
                    ></b
                  >In 2 month
                </div>
                <div class="cb-cart__installment-step">
                  <b
                    ><span class="cb-price-with-icon">
                      {{- 'icon-currency.svg' | inline_asset_content -}}
                      <span>{{ installment_price | money_without_currency }}</span></span
                    ></b
                  >In 3 month
                </div>
              </div>
            </div>

            <a href="/checkout" class="cb-cart__checkout-btn"> Checkout </a>

            <div class="cb-cart__delivery-info">
              <div class="cb-cart__delivery-text">
                <span class="cb-cart__truck-icon">
                  {{- 'icon-truck-cart.svg' | inline_asset_content -}}
                </span>
                Delivered in 1-2 working days
              </div>
              <div class="cb-cart__reviews">
                <span class="cb-cart__stars">★★★★★</span>
                14 reviews
              </div>
            </div>
          </div>
        </aside>
        <a href="{{ routes.all_products_collection_url }}" class="cb-cart__continue-shopping">
          <span class="cb-cart__arrow">{{- 'icon-arrow-cart.svg' | inline_asset_content -}}</span>
          Continue shopping
        </a>
      </div>
    {%- else -%}
      <div class="cb-cart__empty text-center">
        <h2 class="cb-cart__empty-title">{{ 'sections.cart.empty' | t }}</h2>
        <a
          href="{{ routes.all_products_collection_url }}"
          class="cb-cart__checkout-btn"
          style="display:inline-block; width:auto; padding: 15px 40px;"
        >
          {{ 'general.continue_shopping' | t }}
        </a>
      </div>
    {%- endif -%}
    <!-- Tamara Modal Capture -->
    {% capture tamara_modal_content %}
    <div class="cpm-bnpl-modal cpm-tamara-modal">
      
      <h3 class="cpm-tamara-top-title">Pay easier with Tamara</h3>
      
      <div class="cpm-bnpl-center-logo">
        <img src="{{ 'tamara.png' | asset_img_url: '150x' }}" alt="Tamara" width="120" height="40" onerror="this.style.display='none'">
      </div>
      
      <div class="cpm-tamara-options-box">
        <div class="cpm-tamara-option">
          <strong>Split in 4</strong>
          <p>Pay a fraction now and the rest in 3 payments over the next 3 months. No late fees, shariah-compliant!*</p>
        </div>
        <div class="cpm-tamara-option">
          <strong>Pay in Full</strong>
          <p>Pay the full amount today and enjoy exclusive perks with Tamara!*</p>
        </div>
      </div>
      
      <h4 class="cpm-tamara-why-title">Why Tamara?</h4>
      <div class="cpm-tamara-badges">
        <span class="cpm-tamara-badge">Sharia-compliant</span>
        <span class="cpm-tamara-badge">No late fees</span>
        <span class="cpm-tamara-badge">Quick and easy</span>
      </div>
      
      <div class="cpm-bnpl-terms">
        <p>(1) Payment options availability may vary based on your order value and Tamara record.</p>
        <p>(2) Subject to terms and conditions.</p>
        <p>(3) Tamara is Sharia-compliant.</p>
        <p>(4) Eligible for customers in United Arab Emirates.</p>
        <p>(5) Your final payment plan may vary depending on your credit history.</p>
      </div>
    </div>
  {% endcapture %}

    <!-- Tabby Modal Capture -->
    {% capture tabby_modal_content %}
    <div class="cpm-bnpl-modal cpm-tabby-modal">
      <div class="cpm-tabby-header">
        <img src="{{ 'tabby.png' | asset_img_url: '150x' }}" alt="Tabby" width="100" height="30" onerror="this.style.display='none'">
      </div>
      
      <div class="cpm-tabby-slogan">
        <span class="cpm-tabby-pill">Shop now,</span>
        <span class="cpm-tabby-slogan-text">pay over time.</span>
      </div>
      
      <ul class="cpm-tabby-features">
        <li>-No interest. No fees.</li>
        <li>-Trusted by 4,5m+ customers.</li>
        <li>-Shariah-compliant.</li>
      </ul>
      
      <h4 class="cpm-bnpl-subtitle cpm-tabby-how">How it works</h4>
      <ol class="cpm-tabby-steps">
        <li><span>1</span> Choose Tabby at checkout</li>
        <li><span>2</span> Enter your information and add your debit or credit card.</li>
        <li><span>3</span> Your first payment is taken when the order is made.</li>
        <li><span>4</span> We will send you a reminder when your next payment is due</li>
      </ol>
      
      <div class="cpm-tabby-methods">
        <img src="https://cdn.shopify.com/s/images/admin/checkout/payment_methods/mastercard.svg" onerror="this.style.display='none'" width="45" height="28" alt="Mastercard">
        <img src="https://cdn.shopify.com/s/images/admin/checkout/payment_methods/visa.svg" onerror="this.style.display='none'" width="45" height="28" alt="Visa">
        <!-- Google Pay fallback logic to ensure maximum likelihood of hitting correct Shopify asset -->
        <img src="https://cdn.shopify.com/s/images/admin/checkout/payment_methods/google_pay.svg" onerror="this.src='https://cdn.shopify.com/s/images/admin/checkout/payment_methods/googlepay.svg'" width="45" height="28" alt="Google Pay">
      </div>
    </div>
  {% endcapture %}

    {% render 'modal-dialog',
      id: 'tamaraModal',
      title: 'Pay easier with Tamara',
      max_width: '1200px',
      content: tamara_modal_content
    %}
    {% render 'modal-dialog',
      id: 'tabbyModal',
      title: 'Easy Monthly Installments',
      max_width: '1200px',
      content: tabby_modal_content
    %}
  </div>
</div>

{% schema %}
{
  "name": "Custom Cart",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "payment_icon",
      "name": "Payment Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Payment Icon Image"
        },
        {
          "type": "range",
          "id": "icon_height",
          "min": 10,
          "max": 50,
          "step": 1,
          "unit": "px",
          "label": "Icon Height",
          "default": 24
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Cart",
      "blocks": [{ "type": "payment_icon" }, { "type": "payment_icon" }]
    }
  ]
}
{% endschema %}

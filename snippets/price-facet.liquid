{%- assign max_price_cents = filter.range_max | default: 0 -%}
{%- assign min_val_cents = filter.min_value.value | default: 0 -%}
{%- assign max_val_cents = filter.max_value.value | default: max_price_cents -%}

<cb-price-slider class="cb-price-slider-container" data-currency-iso="{{ cart.currency.iso_code }}">
  <div class="price-range">
    <!-- Tooltips for Min and Max -->
    <div class="price-range__callout-container">
      <div class="price-range__callout callout-min" id="PriceCurrent-{{ id_prefix }}-{{ filter.label | handle }}-Min">
        <span class="price-range__value">
          {{- min_val_cents | money_without_trailing_zeros -}}
        </span>
      </div>
      <div class="price-range__callout callout-max" id="PriceCurrent-{{ id_prefix }}-{{ filter.label | handle }}-Max">
        <span class="price-range__value">
          {{- max_val_cents | money_without_trailing_zeros -}}
        </span>
      </div>
    </div>

    <!-- Progress Track -->
    <div class="price-range__slider">
      <div class="price-range__progress"></div>
    </div>

    <!-- Range Inputs -->
    <div class="price-range__inputs">
      <!-- Minimum Node -->
      <input
        type="range"
        class="price-range__input range-min"
        id="{{ id_prefix }}RangeMin-{{ filter.label | handle }}"
        value="{{ min_val_cents }}"
        min="0"
        max="{{ max_price_cents }}"
        step="1"
        aria-label="Minimum price"
      >
      <!-- Maximum Node -->
      <input
        type="range"
        class="price-range__input range-max"
        id="{{ id_prefix }}RangeMax-{{ filter.label | handle }}"
        value="{{ max_val_cents }}"
        min="0"
        max="{{ max_price_cents }}"
        step="1"
        aria-label="Maximum price"
      >
    </div>
  </div>

  <!-- Hidden Native Inputs (Synced with AJAX form) -->
  <div class="facets__price visually-hidden">
    <input
      name="{{ filter.min_value.param_name }}"
      id="{{ id_prefix }}{{ filter.label | handle }}-GTE"
      value="{{ min_val_cents | divided_by: 100.0 | round: 2 }}"
      type="number"
    >
    <input
      name="{{ filter.max_value.param_name }}"
      id="{{ id_prefix }}{{ filter.label | handle }}-LTE"
      value="{{ max_val_cents | divided_by: 100.0 | round: 2 }}"
      type="number"
    >
  </div>
</cb-price-slider>

<script>
  if (!customElements.get('cb-price-slider')) {
    customElements.define(
      'cb-price-slider',
      class extends HTMLElement {
        connectedCallback() {
          this.initSlider();
        }

        initSlider() {
          const inputs = this.querySelectorAll('.price-range__input');
          const calloutMin = this.querySelector('.callout-min');
          const calloutMax = this.querySelector('.callout-max');
          const calloutMinValue = calloutMin.querySelector('.price-range__value');
          const calloutMaxValue = calloutMax.querySelector('.price-range__value');
          const progress = this.querySelector('.price-range__progress');
          const currency = this.dataset.currencyIso;

          // Number formatter to show currency natively
          const formatter = new Intl.NumberFormat(window.Shopify?.locale || 'en-AE', {
            style: 'currency',
            currency: currency,
            minimumFractionDigits: 0,
            maximumFractionDigits: 0,
          });

          const updatePriceUI = (e) => {
            let minVal = parseInt(inputs[0].value) || 0;
            let maxVal = parseInt(inputs[1].value) || 0;
            const maxRange = parseInt(inputs[0].max) || 1;

            // Prevent minimum from exceeding maximum
            if (minVal > maxVal) {
              if (e && e.target === inputs[0]) {
                inputs[0].value = maxVal;
                minVal = maxVal;
              } else {
                inputs[1].value = minVal;
                maxVal = minVal;
              }
            }

            // z-index management so the active tooltip/handle is on top
            if (e) {
              if (e.target.classList.contains('range-min')) {
                inputs[0].style.zIndex = '10';
                inputs[1].style.zIndex = '5';
                calloutMin.style.zIndex = '10';
                calloutMax.style.zIndex = '5';
              } else {
                inputs[1].style.zIndex = '10';
                inputs[0].style.zIndex = '5';
                calloutMax.style.zIndex = '10';
                calloutMin.style.zIndex = '5';
              }
            }

            // Update tooltip text
            calloutMinValue.textContent = formatter.format(minVal / 100.0);
            calloutMaxValue.textContent = formatter.format(maxVal / 100.0);

            // Calculate percentage
            const minPercent = (minVal / maxRange) * 100;
            const maxPercent = (maxVal / maxRange) * 100;

            // Position tooltips
            calloutMin.style.left = minPercent + '%';
            calloutMax.style.left = maxPercent + '%';

            // Keep arrows pointing exactly to the handle instead of breaking alignment
            calloutMax.style.transform = 'translateX(-50%)';
            calloutMin.style.transform = 'translateX(-50%)';

            // Progress bar
            progress.style.left = minPercent + '%';
            progress.style.width = maxPercent - minPercent + '%';

            // Sync with Shopify native form inputs
            const gteInput = this.querySelector('[id$="-GTE"]');
            const lteInput = this.querySelector('[id$="-LTE"]');
            if (gteInput) gteInput.value = (minVal / 100.0).toFixed(2);
            if (lteInput) lteInput.value = (maxVal / 100.0).toFixed(2);
          };

          const onInput = (e) => {
            e.stopPropagation(); // Prevent facet form from auto-submitting while user is actively dragging
            updatePriceUI(e);
          };

          const onChange = (e) => {
            updatePriceUI(e);

            // Allow form submission now that user dropped the handle
            const form = this.closest('facet-filters-form');
            if (form) {
              const event = new Event('input', { bubbles: true });
              this.dispatchEvent(event);
            }
          };

          inputs.forEach((input) => {
            input.addEventListener('input', onInput);
            input.addEventListener('change', onChange);
          });

          // Initial UI setup
          updatePriceUI();
        }
      }
    );
  }
</script>

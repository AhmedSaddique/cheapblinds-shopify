  <!-- Accordions -->
  <div class="cpm-accordions">
    {% for block in section.blocks %}
      {% if block.type == 'accordion' %}
        <div class="cpm-accordion-item" {{ block.shopify_attributes }}>
          <button type="button" class="cpm-accordion-header" onclick="toggleCpmAccordion(this)">
            <span class="cpm-accordion-title">{{ block.settings.title }}</span>
            <span class="cpm-accordion-icon">
              <!-- Plus SVG -->
              <svg
                class="cpm-icon-plus"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d="M12 5V19M5 12H19" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>

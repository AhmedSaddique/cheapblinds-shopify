{%- capture icon_dirham -%}{% render 'icon-dirham', class: 'cpm-dirham-icon' %}{%- endcapture -%}
<div class="cpm-info text-black!">
  <div
    id="cpm-price-results"
    class="cpm-results-container border-2! border-primary! rounded-xl! p-5! mb-6! bg-white! shadow-sm! text-center!"
    style="display: none;"
  >
    <div class="cpm-results-summary">
      <h3 id="cpm-result-dims" class="text-[20px]! text-black! mb-4!"></h3>

      <!-- Dynamic Options Placeholder -->
      <div id="cpm-dynamic-options" class="text-left mb-6 space-y-6"></div>

      <div class="flex! text-[18px]! gap-1! justify-center! items-center! mb-4!">
        <span class="text-[18px]! font-medium!">The Price You Pay</span>
        <div class="flex items-center gap-1">
          <span class="w-[20px] h-auto text-black">
            {%- render 'icon-dirham', class: 'cpm-total-dirham' -%}
          </span>
          <span id="cpm-final-price-val" class="text-[22px]! font-medium! text-black!"></span>
        </div>
      </div>

      <button
        type="button"
        class="cpm-btn cpm-btn-basket w-full! bg-primary! text-black! py-3! px-5! rounded-lg! font-bold! text-[18px]! transition-colors! hover:bg-primary/80!"
      >
        Add to basket
      </button>
    </div>
  </div>

  <div class="cpm-price-row flex items-center gap-1">
    <span class="cpm-price-label">From:</span>
    <span class="w-[16px] h-auto text-black flex items-center">
      {%- render 'icon-dirham', class: 'cpm-base-dirham' -%}
    </span>
    <span class="cpm-price-amount font-bold text-black">
      {{- product.price | money_without_currency -}}
    </span>
  </div>

  <p class="cpm-instruction-text">
    Enter window width and height in the boxes below for an exact made-to-measure price
  </p>

  <!-- Unit selection -->
  <div class="cpm-unit-selector">
    <label class="cpm-radio-label">
      <input type="radio" name="measurement_unit" value="mm" class="cpm-visually-hidden">
      <span class="cpm-custom-radio"></span>
      <span class="cpm-radio-text">mm</span>
    </label>

    <label class="cpm-radio-label">
      <input type="radio" name="measurement_unit" value="cm" class="cpm-visually-hidden" checked>
      <span class="cpm-custom-radio"></span>
      <span class="cpm-radio-text">cm</span>
    </label>

    <label class="cpm-radio-label">
      <input type="radio" name="measurement_unit" value="inches" class="cpm-visually-hidden">
      <span class="cpm-custom-radio"></span>
      <span class="cpm-radio-text">Inches</span>
    </label>
  </div>

  <!-- Measurement Inputs -->
  <div class="cpm-measurements-grid">
    <!-- Width Box -->
    <div
      class="cpm-measure-item"
      data-base-min="{{ product.metafields.custom.minWidth.value | default: product.metafields.custom.min_width.value | default: 300 }}"
      data-base-max="{{ product.metafields.custom.maxWidth.value | default: product.metafields.custom.max_width.value | default: 2600 }}"
    >
      <label for="cpm-width" class="cpm-measure-label"
        >Width (<span class="cpm-unit-display">mm</span>)</label
      >
      <input
        type="number"
        id="cpm-width"
        class="cpm-measure-input cpm-input-width"
        value=""
        step="any"
        min="{{ product.metafields.custom.minWidth.value | default: product.metafields.custom.min_width.value | default: 300 }}"
        max="{{ product.metafields.custom.maxWidth.value | default: product.metafields.custom.max_width.value | default: 2600 }}"
      >

      <div class="cpm-measure-hints">
        Min:
        <span class="cpm-min-val-disp">
          {{-
            product.metafields.custom.minWidth.value
            | default: product.metafields.custom.min_width.value
            | default: '300'
          -}}
        </span>
        <span class="cpm-unit-display-small">mm</span> Max:
        <span class="cpm-max-val-disp">
          {{-
            product.metafields.custom.maxWidth.value
            | default: product.metafields.custom.max_width.value
            | default: '2600'
          -}}
        </span>
        <span class="cpm-unit-display-small">mm</span>
      </div>
      <div
        class="cpm-error-message"
        style="display: none; color: #d9534f; font-size: 13px; margin-top: 6px;"
      ></div>
    </div>

    <!-- Height Box -->
    <div
      class="cpm-measure-item"
      data-base-min="{{ product.metafields.custom.minHeight.value | default: product.metafields.custom.min_height.value | default: 300 }}"
      data-base-max="{{ product.metafields.custom.maxHeight.value | default: product.metafields.custom.max_height.value | default: 3000 }}"
    >
      <label for="cpm-height" class="cpm-measure-label"
        >Height (<span class="cpm-unit-display">mm</span>)</label
      >
      <input
        type="number"
        id="cpm-height"
        class="cpm-measure-input cpm-input-height"
        value=""
        step="any"
        min="{{ product.metafields.custom.minHeight.value | default: product.metafields.custom.min_height.value | default: 300 }}"
        max="{{ product.metafields.custom.maxHeight.value | default: product.metafields.custom.max_height.value | default: 3000 }}"
      >

      <div class="cpm-measure-hints">
        Min:
        <span class="cpm-min-val-disp">
          {{-
            product.metafields.custom.minHeight.value
            | default: product.metafields.custom.min_height.value
            | default: '300'
          -}}
        </span>
        <span class="cpm-unit-display-small">mm</span> | Max:
        <span class="cpm-max-val-disp">
          {{-
            product.metafields.custom.maxHeight.value
            | default: product.metafields.custom.max_height.value
            | default: '3000'
          -}}
        </span>
        <span class="cpm-unit-display-small">mm</span>
      </div>
      <div
        class="cpm-error-message"
        style="display: none; color: #d9534f; font-size: 13px; margin-top: 6px;"
      ></div>
    </div>
  </div>

  <!-- Fitting Type -->
  <div class="cpm-fitting-section mb-6">
    <div class="flex items-center gap-2 mb-3">
      <h3 class="font-semibold text-lg">Choose Fitting Type</h3>
      <button
        type="button"
        class="flex items-center gap-1 text-primary cursor-pointer text-sm"
        onclick="openCpmModal('fittingModal')"
      >
        help
        <span class="border border-primary rounded-full w-4 h-4 flex items-center justify-center text-[10px]"
          >?</span
        >
      </button>
    </div>

    <div class="grid! grid-cols-1! sm:grid-cols-2! gap-2">
      <!-- Outside Recess -->
      <label class="relative cursor-pointer h-full">
        <input
          type="radio"
          name="fitting_type"
          value="Outside Recess"
          class="peer hidden"
          checked
        >
        <div class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg transition-all peer-checked:bg-black peer-checked:border-black peer-checked:text-white h-full relative">
          <div class="w-8 h-8 flex-shrink-0">
            <img
              src="{{ 'detail-page/outside.png' | asset_url }}"
              class="w-full h-full object-contain brightness-100 peer-checked:brightness-0 peer-checked:invert"
              alt="Outside"
            >
          </div>
          <span class="text-[16px]! font-normal!">Outside Recess</span>

          <!-- Checkmark Icon -->
          <div class="hidden peer-checked:flex absolute right-2 top-1/2 -translate-y-1/2 w-5 h-5 rounded-full bg-white items-center justify-center">
            <svg class="w-3 h-3 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
        </div>
      </label>

      <!-- Inside Recess -->
      <label class="relative cursor-pointer h-full">
        <input
          type="radio"
          name="fitting_type"
          value="Inside Recess"
          class="peer hidden"
        >
        <div class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg transition-all peer-checked:bg-black peer-checked:border-black peer-checked:text-white h-full relative">
          <div class="w-8 h-8 flex-shrink-0">
            <img
              src="{{ 'detail-page/inside.png' | asset_url }}"
              class="w-full h-full object-contain brightness-100 peer-checked:brightness-0 peer-checked:invert"
              alt="Inside"
            >
          </div>
          <span class="text-[16px]! font-normal!">Inside Recess</span>

          <!-- Checkmark Icon -->
          <div class="hidden peer-checked:flex absolute right-2 top-1/2 -translate-y-1/2 w-5 h-5 rounded-full bg-white items-center justify-center">
            <svg class="w-3 h-3 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
        </div>
      </label>
    </div>
  </div>

  <button type="button" class="cpm-btn cpm-btn-primary">Get Price</button>

  {% capture fitting_modal_content %}
    <div class="cpm-fitting-modal-info">
      <div class="cpm-fitting-info-row">
        <div class="cpm-fitting-info-img">
          <img src="{{ 'outside.jpeg' | asset_url }}" alt="Outside Recess Guide" width="200" height="200" onerror="this.src='https://via.placeholder.com/200x200?text=Outside+Recess'">
        </div>
        <div class="cpm-fitting-info-text">
          <p><strong>Outside Recess</strong> - Choose this option when fitting your blind outside a window area. If you select outside recess measurements we will make your blind to the outside recess width you have given to us. Please note that the fabric will be slightly narrower than the listed width to accommodate the control mechanism.</p>
        </div>
      </div>
      
      <div class="cpm-fitting-info-row">
        <div class="cpm-fitting-info-img">
          <img src="{{ 'inside.jpeg' | asset_url }}" alt="Inside Recess Guide" width="200" height="200" onerror="this.src='https://via.placeholder.com/200x200?text=Inside+Recess'">
        </div>
        <div class="cpm-fitting-info-text">
          <p><strong>Inside Recess</strong> - Choose this option when fitting your blind inside a window recess. What we will do is reduce the width measurement you enter by 1cm/10mm. This means the blind will fit perfectly inside the recess.</p>
        </div>
      </div>
    </div>
  {% endcapture %}

  {% render 'modal-dialog',
    id: 'fittingModal',
    title: 'Choose Fitting Type',
    max_width: '1000px',
    content: fitting_modal_content
  %}

  {% capture installation_video_content %}
    <div class="p-2">
      <div class="aspect-video bg-gray-100 rounded-lg overflow-hidden flex items-center justify-center relative group cursor-pointer">
        <div class="text-center">
          <svg class="w-16 h-16 text-primary mb-2 mx-auto" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z"/></svg>
          <p class="font-medium text-black!">No-Drill Installation Guide Video</p>
          <p class="text-sm text-gray-500">Coming soon</p>
        </div>
      </div>
      <div class="mt-6 space-y-4 text-black!">
        <h4 class="font-bold text-lg">Why choose Twist&Fit?</h4>
        <p>Our Twist&Fit system allows you to install your blinds in seconds without any tools or mess. It is the perfect solution for anyone who wants a professional result without the stress of drilling.</p>
        <ul class="list-disc pl-5 space-y-2">
          <li><strong>No Tools Required:</strong> Simply twist the mechanism to lock the blind in place.</li>
          <li><strong>Perfect for Rentals:</strong> Leaves no marks or holes in the walls or window frames.</li>
          <li><strong>Ultra-Secure:</strong> Tested to hold even our largest and heaviest blinds.</li>
        </ul>
      </div>
    </div>
  {% endcapture %}

  {% render 'modal-dialog',
    id: 'installationVideoModal',
    title: 'Installation Guide',
    max_width: '800px',
    content: installation_video_content
  %}

  <!-- Info Badges -->
  <div class="cpm-badges-wrapper">
    <!-- BNPL Payments -->
    {{ 'cb-cart.css' | asset_url | stylesheet_tag }}
    <div class="cpm-safe-checkout-wrapper">
      <div
        class="cb-cart__safe-checkout"
        style="font-weight:600; padding-bottom:15px; text-align: start; color: #000"
      >
        Guaranteed Safe Checkout
      </div>

      <!-- Tabby Widget Placeholder -->
      <div class="cb-cart__installment">
        <div class="cb-cart__installment-logo">
          <img src="{{ 'tabby.png' | asset_url }}" alt="Tabby">
        </div>
        <p class="cb-cart__installment-text text-black!">
          Pay 4 interest-free payments of
          <span
            class="text-primary! cursor-pointer hover:underline"
            onclick="openCpmModal('tabbyModal')"
            >Learn more...</span
          >
        </p>
        <div class="cb-cart__installment-table" style="justify-content: start; gap: 16px">
          {% assign installment_price = product.price | divided_by: 4 %}
          <div class="cb-cart__installment-step">
            <b
              ><span class="cb-price-with-icon">
                {{- 'icon-currency.svg' | inline_asset_content -}}
                <span class="cpm-installment-val text-black!">
                  {{- installment_price | money_without_currency -}}
                </span>
              </span></b
            >Today
          </div>
          <div class="cb-cart__installment-step">
            <b
              ><span class="cb-price-with-icon">
                {{- 'icon-currency.svg' | inline_asset_content -}}
                <span class="cpm-installment-val text-black!">
                  {{- installment_price | money_without_currency -}}
                </span>
              </span></b
            >In 1 month
          </div>
          <div class="cb-cart__installment-step">
            <b
              ><span class="cb-price-with-icon">
                {{- 'icon-currency.svg' | inline_asset_content -}}
                <span class="cpm-installment-val text-black!">
                  {{- installment_price | money_without_currency -}}
                </span>
              </span></b
            >In 2 month
          </div>
          <div class="cb-cart__installment-step">
            <b
              ><span class="cb-price-with-icon">
                {{- 'icon-currency.svg' | inline_asset_content -}}
                <span class="cpm-installment-val text-black!">
                  {{- installment_price | money_without_currency -}}
                </span>
              </span></b
            >In 3 month
          </div>
        </div>
      </div>

      <!-- Tamara Widget Placeholder -->
      <div class="cb-cart__installment cb-cart__installment--tamara" style="margin-bottom: 0px">
        <div class="cb-cart__installment-logo">
          <img src="{{ 'tamara.png' | asset_url }}" alt="Tamara">
        </div>
        <p class="cb-cart__installment-text text-black!">
          Pay 4 interest-free payments of
          <span
            class="text-primary! cursor-pointer hover:underline"
            onclick="openCpmModal('tamaraModal')"
            >Learn more...</span
          >
        </p>
        <div class="cb-cart__installment-table" style="justify-content: start; gap: 16px">
          <div class="cb-cart__installment-step">
            <b
              ><span class="cb-price-with-icon">
                {{- 'icon-currency.svg' | inline_asset_content -}}
                <span class="cpm-installment-val text-black!">
                  {{- installment_price | money_without_currency -}}
                </span>
              </span></b
            >Today
          </div>
          <div class="cb-cart__installment-step">
            <b
              ><span class="cb-price-with-icon">
                {{- 'icon-currency.svg' | inline_asset_content -}}
                <span class="cpm-installment-val text-black!">
                  {{- installment_price | money_without_currency -}}
                </span>
              </span></b
            >In 1 month
          </div>
          <div class="cb-cart__installment-step">
            <b
              ><span class="cb-price-with-icon">
                {{- 'icon-currency.svg' | inline_asset_content -}}
                <span class="cpm-installment-val text-black!">
                  {{- installment_price | money_without_currency -}}
                </span>
              </span></b
            >In 2 month
          </div>
          <div class="cb-cart__installment-step">
            <b
              ><span class="cb-price-with-icon">
                {{- 'icon-currency.svg' | inline_asset_content -}}
                <span class="cpm-installment-val text-black!">
                  {{- installment_price | money_without_currency -}}
                </span>
              </span></b
            >In 3 month
          </div>
        </div>
      </div>
    </div>
    <!-- Delivery Box -->
    <div class="cpm-badge-box cpm-delivery-badge">
      <div class="cpm-delivery-left">
        <svg
          class="cpm-truck-icon"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path d="M5 13L2.5 13C2.22386 13 2 12.7761 2 12.5V8.5C2 7.67157 2.67157 7 3.5 7H14.5C15.3284 7 16 7.67157 16 8.5V13C16 13.2761 15.7761 13.5 15.5 13.5H13" stroke="#ffb803" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M16 10H18.5L21.5 13.5V17.5C21.5 17.7761 21.2761 18 21 18H19M16 18H13" stroke="#ffb803" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M16 13.5H21.5" stroke="#ffb803" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="11" cy="18" r="2" stroke="#ffb803" stroke-width="1.5"/>
          <circle cx="17" cy="18" r="2" stroke="#ffb803" stroke-width="1.5"/>
        </svg>
        <span class="cpm-badge-text">Delivered in 1–2 working days</span>
      </div>
      <div class="cpm-delivery-right">
        <div class="cpm-stars">
          <svg viewBox="0 0 24 24" fill="#ffb803" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
          <svg viewBox="0 0 24 24" fill="#ffb803" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
          <svg viewBox="0 0 24 24" fill="#ffb803" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
          <svg viewBox="0 0 24 24" fill="#ffb803" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
          <svg viewBox="0 0 24 24" fill="#ffb803" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
        </div>
        <span class="cpm-review-count">14 reviews</span>
      </div>
    </div>
  </div>

  <!-- Free Sample Box -->
  <div class="cpm-free-sample">
    <div class="cpm-free-sample-content">
      <h4 class="cpm-free-sample-title">Not sure? Order a free sample</h4>
      <p class="cpm-free-sample-sub">Dispatched the same day by first class post</p>
    </div>
    {% assign sample_image = product.images[1] | default: product.featured_image %}
    <button
      type="button"
      class="cpm-sample-btn cb-free-sample-btn"
      data-product-handle="{{ product.handle }}"
      data-product-title="{{ product.title }}"
      data-product-url="{{ product.url }}"
      data-product-image="{{ sample_image | image_url: width: 300 }}"
    >
      <span class="cpm-plus-icon">
        <img width="30" height="30" src="{{ 'icon/sampleIcon.png' | asset_url }}" alt="sampleIcon">
      </span>
      Free Sample
    </button>
  </div>

  <!-- Accordions -->
  <div class="cpm-accordions">
    {% for block in section.blocks %}
      {% if block.type == 'accordion' %}
        <div class="cpm-accordion-item" {{ block.shopify_attributes }}>
          <button type="button" class="cpm-accordion-header" onclick="toggleCpmAccordion(this)">
            <span class="cpm-accordion-title">{{ block.settings.title }}</span>
            <span class="cpm-accordion-icon">
              <!-- Plus SVG -->
              <svg
                class="cpm-icon-plus"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d="M12 5V19M5 12H19" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <!-- Minus SVG -->
              <svg
                class="cpm-icon-minus"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d="M5 12H19" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </button>
          <div class="cpm-accordion-body">
            <div class="cpm-accordion-content">
              {{ block.settings.content }}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <!-- Tamara Modal Capture -->
  {% capture tamara_modal_content %}
    <div class="cpm-bnpl-modal cpm-tamara-modal">
      
      <h3 class="cpm-tamara-top-title">Pay easier with Tamara</h3>
      
      <div class="cpm-bnpl-center-logo">
        <img src="{{ 'tamara.png' | asset_img_url: '150x' }}" alt="Tamara" width="120" height="40" onerror="this.style.display='none'">
      </div>
      
      <div class="cpm-tamara-options-box">
        <div class="cpm-tamara-option">
          <strong>Split in 4</strong>
          <p>Pay a fraction now and the rest in 3 payments over the next 3 months. No late fees, shariah-compliant!*</p>
        </div>
        <div class="cpm-tamara-option">
          <strong>Pay in Full</strong>
          <p>Pay the full amount today and enjoy exclusive perks with Tamara!*</p>
        </div>
      </div>
      
      <h4 class="cpm-tamara-why-title">Why Tamara?</h4>
      <div class="cpm-tamara-badges">
        <span class="cpm-tamara-badge">Sharia-compliant</span>
        <span class="cpm-tamara-badge">No late fees</span>
        <span class="cpm-tamara-badge">Quick and easy</span>
      </div>
      
      <div class="cpm-bnpl-terms">
        <p>(1) Payment options availability may vary based on your order value and Tamara record.</p>
        <p>(2) Subject to terms and conditions.</p>
        <p>(3) Tamara is Sharia-compliant.</p>
        <p>(4) Eligible for customers in United Arab Emirates.</p>
        <p>(5) Your final payment plan may vary depending on your credit history.</p>
      </div>
    </div>
  {% endcapture %}

  <!-- Tabby Modal Capture -->
  {% capture tabby_modal_content %}
    <div class="cpm-bnpl-modal cpm-tabby-modal">
      <div class="cpm-tabby-header">
        <img src="{{ 'tabby.png' | asset_img_url: '150x' }}" alt="Tabby" width="100" height="30" onerror="this.style.display='none'">
      </div>
      
      <div class="cpm-tabby-slogan">
        <span class="cpm-tabby-pill">Shop now,</span>

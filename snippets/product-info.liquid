        if (!selectedOptions[sectionTitle]) {
          selectedOptions[sectionTitle] =
            sectionOptions.find((o) => ['DLXSYS', 'CLASSIC'].includes(o.ChoiceCode)) ||
            sectionOptions[0];
        }

        const sectionDiv = document.createElement('div');
        sectionDiv.className = 'space-y-3';

        const header = `
          <div class="flex items-center gap-2">
            <h3 class="font-semibold text-lg">${getSectionLabel(sectionTitle)}</h3>
            <button type="button" class="flex items-center gap-1 text-primary cursor-pointer text-sm" onclick="openHelpModal('${sectionTitle}')">
              help <span class="border border-primary rounded-full w-4 h-4 flex items-center justify-center text-[10px]">?</span>
            </button>
          </div>
        `;

        const optionsGrid = document.createElement('div');
        optionsGrid.className = 'grid! grid-cols-1! sm:grid-cols-2! gap-2';

        sectionOptions.forEach((opt) => {
          const optLabel = getOptionLabel(sectionTitle, {
            code: opt.ChoiceCode,
            label: opt.ChoiceDescription,
          });
          const optImg =
            OPTION_IMAGE_MAP[opt.ChoiceCode] || "{{ 'icon/cassette.png' | asset_url }}";
          const isSelected = selectedOptions[sectionTitle].ChoiceCode === opt.ChoiceCode;
          const priceAdd = opt.SalesPrice > 0 ? `${parseFloat(opt.SalesPrice).toFixed(1)}` : '';

          const optEl = document.createElement('div');
          optEl.innerHTML = `
            <div class="cpm-opt-card border ${
              isSelected ? 'border-primary bg-primary/5' : 'border-gray-200'
            } rounded-lg p-2 cursor-pointer flex items-center gap-2 transition-all h-full relative" data-section="${sectionTitle}" data-code="${
            opt.ChoiceCode
          }">
              ${
                isSelected
                  ? `
                <div class="absolute -top-2 -left-2 w-5 h-5 rounded-full bg-primary border-2 border-white shadow-sm flex items-center justify-center z-10">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                </div>
              `
                  : ''
              }
              <div class="w-7 h-7 flex-shrink-0">
                <img src="${optImg}" class="w-full h-full object-contain" style="image-rendering: -webkit-optimize-contrast; image-rendering: crisp-edges;" alt="${optLabel}">
              </div>
              <div class="flex-1 flex items-center justify-between">
                <div class="text-[16px]! leading-tight font-normal!">${optLabel}</div>
                ${
                  priceAdd
                    ? `<div class="text-[16px]! font-normal! flex items-center gap-1"><span class="w-[18px] h-auto flex items-center">${ICON_DIRHAM}</span> ${priceAdd}</div>`
                    : ''
                }
              </div>
            </div>
          `;

          optEl.querySelector('.cpm-opt-card').addEventListener('click', () => {
            selectedOptions[sectionTitle] = opt;
            renderDynamicOptions(optionsData); // Re-render to update UI
            updateFinalDisplay();
          });

          optionsGrid.appendChild(optEl);
        });

        sectionDiv.innerHTML = header;
        sectionDiv.appendChild(optionsGrid);
        container.appendChild(sectionDiv);
      });

      // 2. Operation Type (Manual / Motorised) - Now at the end
      if (normalizedCategory !== 'vertical blinds' && motorPrice > 0) {
        const opDiv = document.createElement('div');
        opDiv.className = 'space-y-3 mt-6 pt-4 border-t border-gray-100';
        opDiv.innerHTML = `
          <div class="flex items-center gap-2">
            <h3 class="font-semibold text-lg">Operation Type</h3>
            <button type="button" class="flex items-center gap-1 text-primary cursor-pointer text-sm" onclick="openHelpModal('Operation Type')">
              help <span class="border border-primary rounded-full w-4 h-4 flex items-center justify-center text-[10px]">?</span>
            </button>
          </div>
          <div class="grid! grid-cols-1! sm:grid-cols-2! gap-2 items-stretch">
            <!-- Manual Card -->
            <div class="cpm-opt-card border ${
              !isMotorized ? 'border-primary bg-primary/5' : 'border-gray-200'
            } rounded-lg p-2 cursor-pointer flex items-center gap-2 transition-all h-full min-h-[60px] relative" id="cpm-op-manual">
              ${
                !isMotorized
                  ? `
                <div class="absolute -top-2 -left-2 w-5 h-5 rounded-full bg-primary border-2 border-white shadow-sm flex items-center justify-center z-10">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                </div>
              `
                  : ''
              }
              <div class="w-7 h-7 flex-shrink-0">
                <img src="{{ 'icon/noMotor.png' | asset_url }}" class="w-full h-full object-contain" alt="Manual">
              </div>
              <div class="flex-1">
                <div class="text-[16px]! leading-tight font-normal!">Manual – no extra cost</div>
              </div>
            </div>
            <!-- Motorised Card -->
            <div class="cpm-opt-card border ${
              isMotorized ? 'border-primary bg-primary/5' : 'border-gray-200'
            } rounded-lg p-2 cursor-pointer flex items-center gap-2 transition-all h-full min-h-[60px] relative" id="cpm-op-motor">
              ${
                isMotorized
                  ? `
                <div class="absolute -top-2 -left-2 w-5 h-5 rounded-full bg-primary border-2 border-white shadow-sm flex items-center justify-center z-10">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                </div>
              `
                  : ''
              }
              <div class="w-7 h-7 flex-shrink-0">
                <img src="{{ 'icon/Motor.png' | asset_url }}" class="w-full h-full object-contain" alt="Motorised">
              </div>
              <div class="flex-1 flex flex-col justify-center">
                <div class="text-[16px]! leading-tight font-normal!">Motorised, (with remote)</div>
                <div class="text-[15px]! font-normal! flex items-center gap-1 mt-0.5"><span class="w-[17px] h-auto flex items-center">${ICON_DIRHAM}</span> +${motorPrice.toFixed(
          0
        )}</div>
              </div>
            </div>
          </div>
        `;
        container.appendChild(opDiv);

        opDiv.querySelector('#cpm-op-manual').addEventListener('click', () => {
          isMotorized = false;
          renderDynamicOptions(optionsData);
          updateFinalDisplay();
        });
        opDiv.querySelector('#cpm-op-motor').addEventListener('click', () => {
          isMotorized = true;
          renderDynamicOptions(optionsData);
          updateFinalDisplay();
        });
      }
    }

    if (getPriceBtn) {
      getPriceBtn.addEventListener('click', async function () {
        console.log('Get Price Clicked');
        try {
          if (!validateInput(widthInput) || !validateInput(heightInput)) {
            alert('Please enter valid width and height measurements.');
            return;
          }

          if (!widthInput.value || !heightInput.value) {
            alert('Please enter both width and height.');
            return;
          }

          if (!fabricId || !blindTypeId) {
            console.error('Missing fabricId or blindTypeId in product metafields.');
            alert('Configuration error: Missing fabric or blind type IDs.');
            return;
          }

          const unit = document.querySelector('input[name="measurement_unit"]:checked').value;
          const widthMM = getMeasurementInMM(widthInput.value, unit);
          const dropMM = getMeasurementInMM(heightInput.value, unit);

          getPriceBtn.textContent = 'Calculating...';
          getPriceBtn.disabled = true;

          const originalUrl = `${ILLUMIN8S_BASE_URL}${ILLUMIN8S_FABRIC_PRICE_ENDPOINT}?key=${ILLUMIN8S_API_KEY}&userid=${ILLUMIN8S_RETAILER_ID}&blindtypeid=${fabricId}&fabricid=${blindTypeId}&width=${widthMM}&drop=${dropMM}&retailermasterid=${ILLUMIN8S_RETAILER_MASTER_ID}&measureid=${ILLUMIN8S_MEASURE_ID}`;

          console.log('Fetching price from:', originalUrl);
          const response = await fetch(originalUrl);
          if (!response.ok) throw new Error(`Price API failed with status: ${response.status}`);

          const data = await response.json();
          console.log('API Price Response Data:', data);

          // Fetch Options API
          let optionsData = [];
          try {
            const originalOptionsUrl = `${ILLUMIN8S_BASE_URL}${ILLUMIN8S_OPTIONS_PRICE_ENDPOINT}?key=${ILLUMIN8S_API_KEY}&blindtypeid=${fabricId}&width=${widthMM}&drop=${dropMM}&fabricid=${blindTypeId}&retailerId=${ILLUMIN8S_RETAILER_ID}&retailermasterid=${ILLUMIN8S_RETAILER_MASTER_ID}`;

            console.log('Fetching options from:', originalOptionsUrl);
            const optionsRes = await fetch(originalOptionsUrl);
            console.log('Options Response Status:', optionsRes.status);

            if (optionsRes.ok) {
              optionsData = await optionsRes.json();
              console.log('Category Name:', categoryName);
              console.log('API Options Data:', optionsData);
            } else {
              const errText = await optionsRes.text();
              console.error('Options API Error Response:', errText);
            }
          } catch (optErr) {
            console.error('Error in Options fetch process:', optErr);
          }

          if (data && data.length > 0) {
            const priceData = data[0];
            const resultsContainer = document.getElementById('cpm-price-results');
            const dimsDisp = document.getElementById('cpm-result-dims');
            const fittingType = document.querySelector('input[name="fitting_type"]:checked').value;

            if (resultsContainer && dimsDisp) {
              // Update dimensions text
              dimsDisp.textContent = `${widthInput.value}${unit} width x ${heightInput.value}${unit} drop (${fittingType})`;

              // Set global base price
              basePrice = parseFloat(priceData.TotalSalesAmt) * priceMultiplier;

              // Render options
              renderDynamicOptions(optionsData);

              // initial update of final display
              updateFinalDisplay();

              hasFetchedPrice = true;
              getPriceBtn.textContent = 'Update Price';

              // Show the results section
              resultsContainer.style.display = 'block';

              // Smooth scroll to the results section
              resultsContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          } else {
            console.warn('API returned no results for these parameters.');
            alert('Could not calculate price for these measurements.');
          }
        } catch (error) {
          console.error('Error fetching price:', error);
          alert('An error occurred while calculating the price. Please try again.');
        } finally {
          if (!hasFetchedPrice) {
            getPriceBtn.textContent = 'Get Price';
          } else {
            getPriceBtn.textContent = 'Update Price';
          }
          getPriceBtn.disabled = false;
        }
      });
    }
    // Add to Basket logic
    const addToBasketBtn = document.querySelector('.cpm-btn-basket');
    if (addToBasketBtn) {
      addToBasketBtn.addEventListener('click', () => {
        // Calculate non-motorised options total
        let nonMotorisedOptionsTotal = 0;
        Object.entries(selectedOptions).forEach(([group, opt]) => {
          nonMotorisedOptionsTotal += parseFloat(opt.SalesPrice || 0);
        });

        // Combined Price: Base (API+Markup) + Non-motorised options + Installation
        const combinedPrice =
          basePrice + nonMotorisedOptionsTotal + (isTwistAndFit ? installationPrice : 0);

        // Motorised Price (Separate)
        const currentMotorPrice = isMotorized ? motorPrice : 0;

        // Construct UI-friendly selected options
        const uiSelectedOptions = {};
        Object.entries(selectedOptions).forEach(([sectionTitle, opt]) => {
          const sectionLabel = getSectionLabel(sectionTitle);
          const optionLabel = getOptionLabel(sectionTitle, {
            code: opt.ChoiceCode,
            label: opt.ChoiceDescription,
          });
          uiSelectedOptions[sectionLabel] = optionLabel;
        });

        // Add Operation Type to selected options
        uiSelectedOptions['Operation Type'] = isMotorized ? 'Motorised, (with remote)' : 'Manual – no extra cost';

        // Add Installation Type to selected options
        uiSelectedOptions['Installation Type'] = isTwistAndFit
          ? 'No Drill - Twist&Fit'
          : 'Standard Brackets';

        const cartData = {
          product_title: '{{ product.title }}',
          product_handle: '{{ product.handle }}',
          product_image: '{{ product.featured_image | img_url: "200x200" }}',
          category_name: categoryName,
          isMotorised: isMotorized,
          combined_price_total: combinedPrice.toFixed(2),
          motorised_price: motorPrice.toFixed(2),
          selected_options: uiSelectedOptions,
          dimensions: {
            width: widthInput.value,
            height: heightInput.value,
            unit: document.querySelector('input[name="measurement_unit"]:checked').value,
          },
          fitting_type: document.querySelector('input[name="fitting_type"]:checked').value,
        };

        const unit = document.querySelector('input[name="measurement_unit"]:checked').value;
        // Construct Line Item Properties for Shopify
        const properties = {
          'Width': `${widthInput.value}${unit}`,
          'Height': `${heightInput.value}${unit}`,
          'Fitting Type': cartData.fitting_type,
          'Operation Type': cartData.operation_type,
          'Category': cartData.category_name,
          'Motorised Surcharge': cartData.motorised_price,
          'Options Total': cartData.selectedMotor, // as per user request naming
          '_combined_price': cartData.combined_price_total, // hidden property
        };

        // Add all selected options as individual properties
        Object.entries(cartData.selected_options).forEach(([label, value]) => {
          properties[label] = value;
        });

        console.log('cartDatacartDatacartData', cartData);

        const formData = {
          items: [{
            id: {{ product.selected_or_first_available_variant.id }},
            quantity: 1,
            properties: properties
          }]
        };

        // --- PERSISTENT VIRTUAL CART LOGIC ---
        // Load from localStorage or initialize
        let localCart = JSON.parse(localStorage.getItem('cpm_virtual_cart')) || [];

        // Generate a unique key for this configuration to check for matches
        const configKey = JSON.stringify({
          dims: cartData.dimensions,
          fitting: cartData.fitting_type,
          options: cartData.selected_options
        });

        const existingItem = localCart.find(item => item.configKey === configKey);
        const unitPrice = parseFloat(cartData.combined_price_total);

        if (existingItem) {
          existingItem.quantity += 1;
          existingItem.total_price = (unitPrice * existingItem.quantity).toFixed(2);
          console.log('--- QUANTITY INCREASED (SAVING TO LOCALSTORAGE) ---');
        } else {
          localCart.push({
            ...cartData,
            configKey: configKey,
            quantity: 1,
            total_price: unitPrice.toFixed(2)
          });
          console.log('--- NEW ITEM ADDED (SAVING TO LOCALSTORAGE) ---');
        }

        // Save back to localStorage
        localStorage.setItem('cpm_virtual_cart', JSON.stringify(localCart));
        window.virtualCart = localCart; // also update global window variable

        console.log('VIRTUAL CART PERSISTED:', localCart);

        addToBasketBtn.textContent = 'Added to Basket!';
        
        // Open the virtual drawer
        if (window.openVirtualDrawer) {
          window.openVirtualDrawer();
        }

        setTimeout(() => {
          addToBasketBtn.textContent = 'Add to basket';
        }, 1500);
      });
    }
  });

  // Global Modal Functions
  window.openCpmModal = function (id) {
    var modal = document.getElementById(id);
    if (modal) {
      modal.classList.remove('cpm-modal-hidden');
      document.body.style.overflow = 'hidden';
    }
  };

  window.closeCpmModal = function (id) {
    var modal = document.getElementById(id);
    if (modal) {
      modal.classList.add('cpm-modal-hidden');
      document.body.style.overflow = 'auto'; // restore scroll
    }
  };

  // Close modal when clicking on overlay background
  document.addEventListener('click', function (e) {
    if (e.target.classList.contains('cpm-modal-overlay')) {
      window.closeCpmModal(e.target.id);
    }
  });

  // Accordion toggle logic
  window.toggleCpmAccordion = function (btn) {
    const item = btn.parentElement;
    const allItems = document.querySelectorAll('.cpm-accordion-item');

    // Close others
    allItems.forEach((i) => {
      if (i !== item) {
        i.classList.remove('cpm-accordion-active');
      }
    });

    // Toggle current
    item.classList.toggle('cpm-accordion-active');
  };
</script>


  {% endcapture %}

  {% render 'modal-dialog',
    id: 'tamaraModal',
    title: 'Pay easier with Tamara',
    max_width: '1200px',
    content: tamara_modal_content
  %}
  {% render 'modal-dialog',
    id: 'tabbyModal',
    title: 'Easy Monthly Installments',
    max_width: '1200px',
    content: tabby_modal_content
  %}
</div>

<!-- Basic Script for Unit Change -->
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const unitRadios = document.querySelectorAll('input[name="measurement_unit"]');
    const unitDisplays = document.querySelectorAll('.cpm-unit-display');
    const unitSmallDisplays = document.querySelectorAll('.cpm-unit-display-small');
    const measureItems = document.querySelectorAll('.cpm-measure-item');

    function convertValue(value, unit) {
      if (!value || isNaN(value)) return value;
      let numeric = parseFloat(value);
      if (unit === 'inches') {
        return (numeric / 25.4).toFixed(2);
      } else if (unit === 'cm') {
        let conv = numeric / 10;
        return Number.isInteger(conv) ? conv : conv.toFixed(1);
      } else {
        return Math.round(numeric);
      }
    }

    function updateUnits() {
      const selectedUnit = document.querySelector('input[name="measurement_unit"]:checked').value;
      const displayLabel = selectedUnit === 'inches' ? 'Inches' : selectedUnit;

      unitDisplays.forEach((el) => {
        el.textContent = displayLabel;
      });
      unitSmallDisplays.forEach((el) => {
        el.textContent = displayLabel;
      });

      // Update minimums and maximums according to the base rules
      measureItems.forEach((item) => {
        const baseMin = item.getAttribute('data-base-min');
        const baseMax = item.getAttribute('data-base-max');
        const input = item.querySelector('.cpm-measure-input');
        const minDisp = item.querySelector('.cpm-min-val-disp');
        const maxDisp = item.querySelector('.cpm-max-val-disp');

        const newMin = convertValue(baseMin, selectedUnit);
        const newMax = convertValue(baseMax, selectedUnit);

        if (input) {
          input.min = newMin;
          input.max = newMax;
        }
        if (minDisp) minDisp.textContent = newMin;
        if (maxDisp) maxDisp.textContent = newMax;
      });
    }

    unitRadios.forEach((radio) => {
      radio.addEventListener('change', updateUnits);
    });

    // Set initial unit on load matching checked radio
    updateUnits();
  });

  // Global Modal Functions
  window.openCpmModal = function (id) {
    var modal = document.getElementById(id);
    if (modal) {
      modal.classList.remove('cpm-modal-hidden');
      document.body.style.overflow = 'hidden';
    }
  };

  window.closeCpmModal = function (id) {
    var modal = document.getElementById(id);
    if (modal) {
      modal.classList.add('cpm-modal-hidden');
      document.body.style.overflow = 'auto'; // restore scroll
    }
  };

  // Close modal when clicking on overlay background
  document.addEventListener('click', function (e) {
    if (e.target.classList.contains('cpm-modal-overlay')) {
      window.closeCpmModal(e.target.id);
    }
  });

  // Accordion toggle logic
  window.toggleCpmAccordion = function (btn) {
    const item = btn.parentElement;
    const allItems = document.querySelectorAll('.cpm-accordion-item');

    // Close others
    allItems.forEach((i) => {
      if (i !== item) {
        i.classList.remove('cpm-accordion-active');
      }
    });

    // Toggle current
    item.classList.toggle('cpm-accordion-active');
  };
</script>

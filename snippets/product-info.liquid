<!-- Basic Script for Unit Change -->
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const unitRadios = document.querySelectorAll('input[name="measurement_unit"]');
    const unitDisplays = document.querySelectorAll('.cpm-unit-display');
    const unitSmallDisplays = document.querySelectorAll('.cpm-unit-display-small');
    const measureItems = document.querySelectorAll('.cpm-measure-item');

    function convertValue(value, unit) {
      if (!value || isNaN(value)) return value;
      let numeric = parseFloat(value);
      if (unit === 'inches') {
        return (numeric / 25.4).toFixed(2);
      } else if (unit === 'cm') {
        let conv = numeric / 10;
        return Number.isInteger(conv) ? conv : conv.toFixed(1);
      } else {
        return Math.round(numeric);
      }
    }

    function updateUnits() {
      const selectedUnit = document.querySelector('input[name="measurement_unit"]:checked').value;
      const displayLabel = selectedUnit === 'inches' ? 'Inches' : selectedUnit;

      unitDisplays.forEach((el) => {
        el.textContent = displayLabel;
      });
      unitSmallDisplays.forEach((el) => {
        el.textContent = displayLabel;
      });

      // Update minimums and maximums according to the base rules
      measureItems.forEach((item) => {
        const baseMin = item.getAttribute('data-base-min');
        const baseMax = item.getAttribute('data-base-max');
        const input = item.querySelector('.cpm-measure-input');
        const minDisp = item.querySelector('.cpm-min-val-disp');
        const maxDisp = item.querySelector('.cpm-max-val-disp');

        const newMin = convertValue(baseMin, selectedUnit);
        const newMax = convertValue(baseMax, selectedUnit);

        if (input) {
          input.min = newMin;
          input.max = newMax;
        }
        if (minDisp) minDisp.textContent = newMin;
        if (maxDisp) maxDisp.textContent = newMax;

        if (input && input.value) {
          validateInput(input);
        }
      });
    }

    function validateInput(input) {
      const min = parseFloat(input.min);
      const max = parseFloat(input.max);
      const val = parseFloat(input.value);
      const errorDiv = input.closest('.cpm-measure-item').querySelector('.cpm-error-message');
      const unit = document.querySelector('input[name="measurement_unit"]:checked').value;
      const displayLabel = unit === 'inches' ? 'Inches' : unit;

      if (!input.value) {
        errorDiv.style.display = 'none';
        input.style.borderColor = '';
        return true;
      }

      if (val < min || val > max) {
        errorDiv.textContent = `Value must be between ${min} and ${max} ${displayLabel}.`;
        errorDiv.style.display = 'block';
        input.style.borderColor = '#d9534f';
        return false;
      } else {
        errorDiv.style.display = 'none';
        input.style.borderColor = '';
        return true;
      }
    }

    const inputs = document.querySelectorAll('.cpm-measure-input');
    inputs.forEach((input) => {
      input.addEventListener('input', () => validateInput(input));
      input.addEventListener('blur', () => validateInput(input));
    });

    unitRadios.forEach((radio) => {
      radio.addEventListener('change', updateUnits);
    });

    // Set initial unit on load matching checked radio
    updateUnits();

    // API Price Fetching
    const getPriceBtn = document.querySelector('.cpm-btn-primary');
    const widthInput = document.getElementById('cpm-width');
    const heightInput = document.getElementById('cpm-height');
    const priceAmountDisp = document.querySelector('.cpm-price-amount');

    const ILLUMIN8S_API_KEY = 'pk.5bb50868ead0d6385b902321aa3ec294';
    const ILLUMIN8S_BASE_URL = 'https://apigateway.illumin8global.com:4200';
    const ILLUMIN8S_FABRIC_PRICE_ENDPOINT = '/api/fabricprice';
    const ILLUMIN8S_OPTIONS_PRICE_ENDPOINT = '/api/optionprice';
    ILLUMIN8S_RETAILER_ID = '4967';
    ILLUMIN8S_RETAILER_MASTER_ID = '444';
    ILLUMIN8S_MEASURE_ID = '83';

    // Metafields - Trying multiple common naming conventions
    const fabricId =
      '{{ product.metafields.custom.fabricId.value | default: product.metafields.custom.fabricid.value | default: product.metafields.custom.fabric_id.value }}';
    const blindTypeId =
      '{{ product.metafields.custom.blindTypeId.value | default: product.metafields.custom.blindtypeid.value | default: product.metafields.custom.blind_type_id.value }}';
    const categoryName =
      '{{ product.metafields.custom.categoryName.value | default: product.metafields.custom.category_name.value }}';

    function getMeasurementInMM(val, unit) {
      let numeric = parseFloat(val);
      if (unit === 'inches') return Math.round(numeric * 25.4);
      if (unit === 'cm') return Math.round(numeric * 10);
      return Math.round(numeric);
    }

    if (getPriceBtn) {
      getPriceBtn.addEventListener('click', async function () {
        if (!validateInput(widthInput) || !validateInput(heightInput)) {
          alert('Please enter valid width and height measurements.');
          return;
        }

        if (!widthInput.value || !heightInput.value) {
          alert('Please enter both width and height.');
          return;
        }

        if (!fabricId || !blindTypeId) {
          console.error('Missing fabricId or blindTypeId in product metafields.');
          alert('Configuration error: Missing fabric or blind type IDs.');
          return;
        }

        const unit = document.querySelector('input[name="measurement_unit"]:checked').value;
        const widthMM = getMeasurementInMM(widthInput.value, unit);
        const dropMM = getMeasurementInMM(heightInput.value, unit);

        getPriceBtn.textContent = 'Calculating...';
        getPriceBtn.disabled = true;

        try {
          const originalUrl = `${ILLUMIN8S_BASE_URL}${ILLUMIN8S_FABRIC_PRICE_ENDPOINT}?key=${ILLUMIN8S_API_KEY}&userid=${ILLUMIN8S_RETAILER_ID}&blindtypeid=${fabricId}&fabricid=${blindTypeId}&width=${widthMM}&drop=${dropMM}&retailermasterid=${ILLUMIN8S_RETAILER_MASTER_ID}&measureid=${ILLUMIN8S_MEASURE_ID}`;

          console.log('Fetching price from:', originalUrl);
          const response = await fetch(originalUrl);
          if (!response.ok) throw new Error(`Price API failed with status: ${response.status}`);

          const data = await response.json();
          console.log('API Price Response Data:', data);

          // Fetch Options API
          try {
            const originalOptionsUrl = `${ILLUMIN8S_BASE_URL}${ILLUMIN8S_OPTIONS_PRICE_ENDPOINT}?key=${ILLUMIN8S_API_KEY}&blindtypeid=${fabricId}&width=${widthMM}&drop=${dropMM}&fabricid=${blindTypeId}&retailerId=${ILLUMIN8S_MEASURE_ID}&retailermasterid=${ILLUMIN8S_RETAILER_MASTER_ID}`;

            console.log('Fetching options from:', originalOptionsUrl);
            const optionsRes = await fetch(originalOptionsUrl);
            console.log('Options Response Status:', optionsRes.status);

            if (optionsRes.ok) {
              const optionsData = await optionsRes.json();
              console.log('Category Name:', categoryName);
              console.log('API Options Data:', optionsData);
            } else {
              const errText = await optionsRes.text();
              console.error('Options API Error Response:', errText);
            }
          } catch (optErr) {
            console.error('Error in Options fetch process:', optErr);
          }

          if (data && data.length > 0) {
            const priceData = data[0];
            const resultsContainer = document.getElementById('cpm-price-results');
            const dimsDisp = document.getElementById('cpm-result-dims');
            const finalPriceVal = document.getElementById('cpm-final-price-val');
            const fittingType = document.querySelector('input[name="fitting_type"]:checked').value;

            if (resultsContainer && dimsDisp && finalPriceVal) {
              // Update dimensions text e.g. 300cm width x 300cm drop (Inside Recess)
              dimsDisp.textContent = `${widthInput.value}${unit} width x ${heightInput.value}${unit} drop (${fittingType})`;

              // Update final price using TotalSalesAmt
              finalPriceVal.textContent = priceData.TotalSalesAmt.toFixed(2);

              // Show the results section
              resultsContainer.style.display = 'block';

              // Smooth scroll to the results section
              resultsContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          } else {
            console.warn('API returned no results for these parameters.');
            alert('Could not calculate price for these measurements.');
          }
        } catch (error) {
          console.error('Error fetching price:', error);
          alert('An error occurred while calculating the price. Please try again.');
        } finally {
          getPriceBtn.textContent = 'Get Price';
          getPriceBtn.disabled = false;
        }
      });
    }
  });

  // Global Modal Functions
  window.openCpmModal = function (id) {
    var modal = document.getElementById(id);
    if (modal) {
      modal.classList.remove('cpm-modal-hidden');
      document.body.style.overflow = 'hidden';
    }
  };

  window.closeCpmModal = function (id) {
    var modal = document.getElementById(id);
    if (modal) {
      modal.classList.add('cpm-modal-hidden');
      document.body.style.overflow = 'auto'; // restore scroll
    }
  };

  // Close modal when clicking on overlay background
  document.addEventListener('click', function (e) {
    if (e.target.classList.contains('cpm-modal-overlay')) {
      window.closeCpmModal(e.target.id);
    }
  });

  // Accordion toggle logic
  window.toggleCpmAccordion = function (btn) {
    const item = btn.parentElement;
    const allItems = document.querySelectorAll('.cpm-accordion-item');

    // Close others
    allItems.forEach((i) => {
      if (i !== item) {
        i.classList.remove('cpm-accordion-active');
      }
    });

    // Toggle current
    item.classList.toggle('cpm-accordion-active');
  };
</script>

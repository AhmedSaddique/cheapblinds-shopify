<div class="cpm-info">
  <!--
    Desktop Title is usually handled by theme, but we can also add it if not present. Let's start with Price
  -->

  <div class="cpm-price-row">
    <span class="cpm-price-label">From:</span>
    <span class="cpm-price-amount">{{ product.price | money }}</span>
  </div>

  <p class="cpm-instruction-text">
    Enter window width and height in the boxes below for an exact made-to-measure price
  </p>

  <!-- Unit selection -->
  <div class="cpm-unit-selector">
    <label class="cpm-radio-label">
      <input type="radio" name="measurement_unit" value="mm" class="cpm-visually-hidden" checked>
      <span class="cpm-custom-radio"></span>
      <span class="cpm-radio-text">mm</span>
    </label>

    <label class="cpm-radio-label">
      <input type="radio" name="measurement_unit" value="cm" class="cpm-visually-hidden">
      <span class="cpm-custom-radio"></span>
      <span class="cpm-radio-text">cm</span>
    </label>

    <label class="cpm-radio-label">
      <input type="radio" name="measurement_unit" value="inches" class="cpm-visually-hidden">
      <span class="cpm-custom-radio"></span>
      <span class="cpm-radio-text">Inches</span>
    </label>
  </div>

  <!-- Measurement Inputs -->
  <div class="cpm-measurements-grid">
    <!-- Width Box -->
    <div
      class="cpm-measure-item"
      data-base-min="{{ product.metafields.custom['min-width'] | default: 300 }}"
      data-base-max="{{ product.metafields.custom['max-width'] | default: 2600 }}"
    >
      <label for="cpm-width" class="cpm-measure-label"
        >Width (<span class="cpm-unit-display">mm</span>)</label
      >
      <input
        type="number"
        id="cpm-width"
        class="cpm-measure-input cpm-input-width"
        value=""
        step="any"
        min="{{ product.metafields.custom['min-width'] | default: 300 }}"
        max="{{ product.metafields.custom['max-width'] | default: 2600 }}"
      >

      <div class="cpm-measure-hints">
        Min:
        <span class="cpm-min-val-disp">
          {{- product.metafields.custom['min-width'] | default: '300' -}}
        </span>
        <span class="cpm-unit-display-small">mm</span> Max:
        <span class="cpm-max-val-disp">
          {{- product.metafields.custom['max-width'] | default: '2600' -}}
        </span>
        <span class="cpm-unit-display-small">mm</span>
      </div>
    </div>

    <!-- Height Box -->
    <div
      class="cpm-measure-item"
      data-base-min="{{ product.metafields.custom['min-height'] | default: 300 }}"
      data-base-max="{{ product.metafields.custom['max-height'] | default: 3000 }}"
    >
      <label for="cpm-height" class="cpm-measure-label"
        >Height (<span class="cpm-unit-display">mm</span>)</label
      >
      <input
        type="number"
        id="cpm-height"
        class="cpm-measure-input cpm-input-height"
        value=""
        step="any"
        min="{{ product.metafields.custom['min-height'] | default: 300 }}"
        max="{{ product.metafields.custom['max-height'] | default: 3000 }}"
      >

      <div class="cpm-measure-hints">
        Min:
        <span class="cpm-min-val-disp">
          {{- product.metafields.custom['min-height'] | default: '300' -}}
        </span>
        <span class="cpm-unit-display-small">mm</span> | Max:
        <span class="cpm-max-val-disp">
          {{- product.metafields.custom['max-height'] | default: '3000' -}}
        </span>
        <span class="cpm-unit-display-small">mm</span>
      </div>
    </div>
  </div>

  <!-- Fitting Type -->
  <div class="cpm-fitting-section">
    <div class="cpm-fitting-header">
      <span class="cpm-fitting-title">Choose Fitting Type</span>
      <button type="button" class="cpm-help-link" onclick="openCpmModal('fittingModal')">
        Help <span class="cpm-help-icon">?</span>
      </button>
    </div>

    <div class="cpm-fitting-options">
      <!-- Outside Recess -->
      <label class="cpm-fitting-label">
        <input
          type="radio"
          name="fitting_type"
          value="Outside Recess"
          class="cpm-visually-hidden cpm-fitting-radio"
          checked
        >
        <div class="cpm-fitting-box">
          <span class="cpm-fitting-text">Outside Recess</span>
          <svg
            class="cpm-fitting-check"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <circle cx="12" cy="12" r="10" fill="#fff"/><path d="M8 12.5L10.5 15L16 9" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </label>

      <!-- Inside Recess -->
      <label class="cpm-fitting-label">
        <input
          type="radio"
          name="fitting_type"
          value="Inside Recess"
          class="cpm-visually-hidden cpm-fitting-radio"
        >
        <div class="cpm-fitting-box">
          <span class="cpm-fitting-text">Inside Recess</span>
          <svg
            class="cpm-fitting-check"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <circle cx="12" cy="12" r="10" fill="#fff"/><path d="M8 12.5L10.5 15L16 9" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </label>
    </div>
  </div>

  <button type="button" class="cpm-btn cpm-btn-primary">Get Price</button>

  {% capture fitting_modal_content %}
    <div class="cpm-fitting-modal-info">
      <div class="cpm-fitting-info-row">
        <div class="cpm-fitting-info-img">
          <img src="{{ 'outside.jpeg' | asset_url }}" alt="Outside Recess Guide" width="200" height="200" onerror="this.src='https://via.placeholder.com/200x200?text=Outside+Recess'">
        </div>
        <div class="cpm-fitting-info-text">
          <p><strong>Outside Recess</strong> - Choose this option when fitting your blind outside a window area. If you select outside recess measurements we will make your blind to the outside recess width you have given to us. Please note that the fabric will be slightly narrower than the listed width to accommodate the control mechanism.</p>
        </div>
      </div>
      
      <div class="cpm-fitting-info-row">
        <div class="cpm-fitting-info-img">
          <img src="{{ 'inside.jpeg' | asset_url }}" alt="Inside Recess Guide" width="200" height="200" onerror="this.src='https://via.placeholder.com/200x200?text=Inside+Recess'">
        </div>
        <div class="cpm-fitting-info-text">
          <p><strong>Inside Recess</strong> - Choose this option when fitting your blind inside a window recess. What we will do is reduce the width measurement you enter by 1cm/10mm. This means the blind will fit perfectly inside the recess.</p>
        </div>
      </div>
    </div>
  {% endcapture %}

  {% render 'modal-dialog',
    id: 'fittingModal',
    title: 'Choose Fitting Type',
    max_width: '1000px',
    content: fitting_modal_content
  %}

  <!-- Info Badges -->
  <div class="cpm-badges-wrapper">
    <!-- BNPL Payments -->
    {{ 'cb-cart.css' | asset_url | stylesheet_tag }}
    <div class="cpm-safe-checkout-wrapper">

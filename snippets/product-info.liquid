    <div class="cpm-free-sample-content">
      <h4 class="cpm-free-sample-title">Not sure? Order a free sample</h4>
      <p class="cpm-free-sample-sub">Dispatched the same day by first class post</p>
    </div>
    <button type="button" class="cpm-sample-btn">
      <span class="cpm-plus-icon">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          style="width: 14px; height: 14px;"
        >
          <path d="M12 5V19M5 12H19" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>

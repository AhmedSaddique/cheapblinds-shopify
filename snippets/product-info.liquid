        const resultsContainer = document.getElementById('cpm-price-results');
        if (resultsContainer && resultsContainer.style.display !== 'none') {
          if (window.lastOptionsData) {
            renderDynamicOptions(window.lastOptionsData);
          }
          updateFinalDisplay();
        }
      });

        <div class="cb-cart__installment-logo">
          <img src="{{ 'tamara.png' | asset_url }}" alt="Tamara">
        </div>
        <p class="cb-cart__installment-text">
          Pay 4 interest-free payments of
          <span onclick="openCpmModal('tamaraModal')" style="cursor:pointer">Learn more...</span>
        </p>
        <div class="cb-cart__installment-table" style="justify-content: start; gap: 16px">
          <div class="cb-cart__installment-step">
            <b
              ><span class="cb-price-with-icon">
                {{- 'icon-currency.svg' | inline_asset_content -}}
                <span>{{ installment_price | money_without_currency }}</span>
              </span></b
            >Today
          </div>
          <div class="cb-cart__installment-step">
            <b
              ><span class="cb-price-with-icon">
                {{- 'icon-currency.svg' | inline_asset_content -}}
                <span>{{ installment_price | money_without_currency }}</span>
              </span></b
            >In 1 month
          </div>
          <div class="cb-cart__installment-step">
            <b
              ><span class="cb-price-with-icon">
                {{- 'icon-currency.svg' | inline_asset_content -}}
                <span>{{ installment_price | money_without_currency }}</span>
              </span></b
            >In 2 month
          </div>
          <div class="cb-cart__installment-step">
            <b
              ><span class="cb-price-with-icon">
                {{- 'icon-currency.svg' | inline_asset_content -}}
                <span>{{ installment_price | money_without_currency }}</span>
              </span></b
            >In 3 month
          </div>
        </div>
      </div>
    </div>
    <!-- Delivery Box -->
    <div class="cpm-badge-box cpm-delivery-badge">
      <div class="cpm-delivery-left">
        <svg
          class="cpm-truck-icon"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path d="M5 13L2.5 13C2.22386 13 2 12.7761 2 12.5V8.5C2 7.67157 2.67157 7 3.5 7H14.5C15.3284 7 16 7.67157 16 8.5V13C16 13.2761 15.7761 13.5 15.5 13.5H13" stroke="#ffb803" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M16 10H18.5L21.5 13.5V17.5C21.5 17.7761 21.2761 18 21 18H19M16 18H13" stroke="#ffb803" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M16 13.5H21.5" stroke="#ffb803" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="11" cy="18" r="2" stroke="#ffb803" stroke-width="1.5"/>
          <circle cx="17" cy="18" r="2" stroke="#ffb803" stroke-width="1.5"/>
        </svg>
        <span class="cpm-badge-text">Delivered in 1–2 working days</span>
      </div>
      <div class="cpm-delivery-right">
        <div class="cpm-stars">
          <svg viewBox="0 0 24 24" fill="#ffb803" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
          <svg viewBox="0 0 24 24" fill="#ffb803" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
          <svg viewBox="0 0 24 24" fill="#ffb803" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
          <svg viewBox="0 0 24 24" fill="#ffb803" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
          <svg viewBox="0 0 24 24" fill="#ffb803" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>

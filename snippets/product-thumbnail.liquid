<!-- Mobile Title -->
<h1 class="cpm-title">
  {{ product.title | default: 'Luft Noir Screen Roller Blinds' }}
</h1>

<div class="cpm-gallery-wrapper">
  <!-- Promotional Banner Over Image Container -->
  <div class="cpm-promo-banner">
    <span class="cpm-promo-main">BUY 1 GET FREE</span>
    <span class="cpm-promo-sub">End Soon</span>
  </div>

  <!-- Main Product Slider -->
  <div class="swiper cpm-main-swiper">
    <div class="swiper-wrapper">
      {% if product.media.size > 0 %}
        {% for media in product.media %}
          <div class="swiper-slide">
            <img
              src="{{ media | image_url: width: 1000 }}"
              alt="{{ media.alt | escape }}"
              loading="lazy"
              width="{{ media.width | default: 700 }}"
              height="{{ media.height | default: 700 }}"
              class="cpm-slide-image"
            >
          </div>
        {% endfor %}
      {% else %}
        {% assign dev_thumbs = '1,2,3,4,5' | split: ',' %}
        {% for d in dev_thumbs %}
          <div class="swiper-slide">
            <!-- Placeholder using a div with background color -->
            <div style="background:#555; width:100%; aspect-ratio:1/1; display:flex; align-items:center; justify-content:center; color:#fff;">
              Product Image {{ d }}
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <!-- Absolute Positioning Badge for Same Day Express (Top-left near bottom) -->
    <div class="cpm-badge-overlay">
      <!--
        In an actual theme, we could upload an image. For now, we will add a fallback HTML badge or user can link the image later
      -->
      <img
        src="{{ 'same-day-express.png' | asset_img_url: 'medium' }}"
        alt="Same Day Express"
        width="150"
        height="150"
        onerror="this.style.display='none'"
      >
    </div>
  </div>

  <!-- Thumbnails Slider -->
  <div class="swiper cpm-thumb-swiper">
    <div class="swiper-wrapper">
      {% if product.media.size > 0 %}
        {% for media in product.media %}
          <div class="swiper-slide cpm-thumb-slide">
            <img
              src="{{ media | image_url: width: 200 }}"
              alt="{{ media.alt | escape }}"
              loading="lazy"
              width="200"
              height="200"
              class="cpm-thumb-image"
            >
          </div>
        {% endfor %}
      {% else %}
        {% assign dev_thumbs = '1,2,3,4,5' | split: ',' %}
        {% for d in dev_thumbs %}
          <div class="swiper-slide cpm-thumb-slide">
            <div style="background:#777; width:100%; aspect-ratio:1/1; display:flex; align-items:center; justify-content:center; color:#fff; font-size:12px;">
              Thumb {{ d }}
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

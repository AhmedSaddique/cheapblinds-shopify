{% comment %}
  Renders a product card

  Accepts:
  - card_product: {Object} Product Liquid object (optional)
  - media_aspect_ratio: {String} Size of the product image card. Values are "square" and "portrait". Default is "square" (optional)
  - lazy_load: {Boolean} Image should be lazy loaded. Default: true (optional)
  - section_id: {String} The ID of the section that contains this card.

  Usage:
  {% render 'card-product', card_product: product, section_id: section.id %}
{% endcomment %}

{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'cb-product-grid.css' | asset_url | stylesheet_tag }}

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign ratio = 1
    if card_product.featured_media and media_aspect_ratio == 'portrait'
      assign ratio = 0.8
    elsif card_product.featured_media and media_aspect_ratio == 'adapt'
      assign ratio = card_product.featured_media.aspect_ratio
    endif
    if ratio == 0 or ratio == null
      assign ratio = 1
    endif

    assign discount = 30
    if card_product.compare_at_price > card_product.price
      assign discount = card_product.compare_at_price | minus: card_product.price | times: 100.0 | divided_by: card_product.compare_at_price | round
    endif
  -%}

  <div class="card-wrapper product-card-wrapper">
    <div class="card card--product">
      <div class="card__inner ratio" style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;">
        {%- if card_product.featured_media -%}
          <div class="card__media">
            <a href="{{ card_product.url }}" class="full-unstyled-link">
              <div class="media media--transparent media--hover-effect">
                <img
                  srcset="
                    {%- if card_product.featured_media.width >= 165 -%}{{ card_product.featured_media | image_url: width: 165 }} 165w,{%- endif -%}
                    {%- if card_product.featured_media.width >= 360 -%}{{ card_product.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
                    {%- if card_product.featured_media.width >= 533 -%}{{ card_product.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
                    {{ card_product.featured_media | image_url }} {{ card_product.featured_media.width }}w
                  "
                  src="{{ card_product.featured_media | image_url: width: 533 }}"
                  sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                  alt="{{ card_product.featured_media.alt | escape }}"
                  class="motion-reduce"
                  {% unless lazy_load == false %}
                    loading="lazy"
                  {% endunless %}
                  width="{{ card_product.featured_media.width }}"
                  height="{{ card_product.featured_media.height }}"
                >
              </div>
            </a>
          </div>
        {%- endif -%}

        {%- if discount > 0 -%}
          <div class="cb-discount-badge">
            {{ discount }}%
            <span>OFF</span>
          </div>
        {%- endif -%}

        {%- assign same_day = card_product.metafields.custom.same_day_delivery.value -%}
        {%- if same_day == true or same_day == 'true' or same_day == 'True' -%}
          <div class="cb-same-day-badge">
            <img
              src="{{ 'icon-same-day.svg' | asset_url }}"
              alt="Same Day Delivery"
              class="cb-same-day-icon"
              width="120"
              height="120"
              loading="lazy"
            >
          </div>
        {%- endif -%}
      </div>
      <div class="cb-product-card-body-wrapper">
        <div class="cb-product-card-body">
          <div class="cb-product-details">
            <div class="cb-product-title-wrapper">
              <h3 class="cb-product-title">
                <a href="{{ card_product.url }}" class="full-unstyled-link">{{ card_product.title | escape }}</a>
              </h3>
              {%- assign color_code = card_product.metafields.custom.color_code.value -%}
              {%- if color_code != blank -%}
                {%- if color_code contains '#' -%}
                  {%- assign swatch_color = color_code -%}
                {%- else -%}
                  {%- assign swatch_color = '#' | append: color_code -%}
                {%- endif -%}
                <div class="cb-color-swatch" style="background-color: {{ swatch_color }};"></div>
              {%- elsif card_product.featured_media -%}
                <div
                  class="cb-product-swatch-large"
                  style="background-image: url({{ card_product.featured_media | image_url: width: 150 }});"
                ></div>
              {%- endif -%}
            </div>
          </div>
        </div>
        <div class="cb-product-card-body-footer">
          <div class="cb-product-price-from">
            From
            <div class="cb-product-price">
              {{ card_product.price | money }}
            </div>
          </div>
          <div class="cb-card-actions">
            <button
              class="cb-free-sample-btn"
              aria-label="Add free sample"
              data-product-handle="{{ card_product.handle }}"
              data-product-title="{{ card_product.title | escape }}"
              data-product-price="{{ card_product.price | money | escape }}"
              data-product-url="{{ card_product.url }}"
              data-product-image="{% if card_product.featured_media %}{{ card_product.featured_media | image_url: width: 533 }}{% endif %}"
              data-product-compare-price="{{ card_product.compare_at_price | money | escape }}"
              data-product-discount="{{ discount }}"
              data-product-same-day="{% if same_day == true or same_day == 'true' or same_day == 'True' %}true{% else %}false{% endif %}"
              data-product-color="{% if swatch_color != blank %}{{ swatch_color }}{% endif %}"
              data-product-swatch-image="{% if swatch_color == blank and card_product.featured_media %}{{ card_product.featured_media | image_url: width: 150 }}{% endif %}"
            >
              {{ card_btn_text | default: 'Free Sample' }}
            </button>
            <button
              class="cb-wishlist-button"
              aria-label="Add to wishlist"
              data-product-handle="{{ card_product.handle }}"
              data-product-title="{{ card_product.title | escape }}"
              data-product-price="{{ card_product.price | money | escape }}"
              data-product-url="{{ card_product.url }}"
              data-product-image="{% if card_product.featured_media %}{{ card_product.featured_media | image_url: width: 533 }}{% endif %}"
              data-product-compare-price="{{ card_product.compare_at_price | money | escape }}"
              data-product-discount="{{ discount }}"
              data-product-same-day="{% if same_day == true or same_day == 'true' or same_day == 'True' %}true{% else %}false{% endif %}"
              data-product-color="{% if swatch_color != blank %}{{ swatch_color }}{% endif %}"
              data-product-swatch-image="{% if swatch_color == blank and card_product.featured_media %}{{ card_product.featured_media | image_url: width: 150 }}{% endif %}"
              data-variant-id="{{ card_product.selected_or_first_available_variant.id }}"
            >
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="#ffb800" stroke-width="1.5"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
{%- else -%}
  <div class="card-wrapper product-card-wrapper">
    <div class="card card--product">
      <div class="card__inner ratio" style="--ratio-percent: 100%;">
        <div class="card__media">
          <div class="media media--transparent">
            {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        </div>
      </div>
      <div class="cb-product-card-body">
        <div class="cb-product-details">
          <h3 class="cb-product-title">
            <a role="link" aria-disabled="true" class="full-unstyled-link">{{ 'onboarding.product_title' | t }}</a>
          </h3>
          <div class="cb-product-price">
            {{ 1999 | money }}
          </div>
        </div>
      </div>
      <div class="cb-card-actions">
        <a role="link" aria-disabled="true" class="cb-free-sample-btn">Free Sample</a>
      </div>
    </div>
  </div>
{%- endif -%}

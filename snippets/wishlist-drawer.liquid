<div class="wishlist-drawer-wrapper" id="WishlistDrawer" aria-modal="true" role="dialog" tabindex="-1">
  <div class="wishlist-drawer__overlay" id="WishlistOverlay"></div>
  <div class="wishlist-drawer__inner">
    <div class="wishlist-drawer__header">
      <h2 class="wishlist-drawer__heading">Your Wishlist</h2>
      <button class="wishlist-drawer__close" id="WishlistClose" aria-label="Close wishlist">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
    <div class="wishlist-drawer__body" id="WishlistBody">
      <!-- Items will be injected here via JS -->
      <div class="wishlist-drawer__empty hide">
        <p>Your wishlist is currently empty.</p>
        <a href="{{ routes.all_products_collection_url }}" class="button button--primary" onclick="document.getElementById('WishlistClose').click();">Continue shopping</a>
      </div>
    </div>
  </div>
</div>
